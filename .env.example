# =============================================================================
# Sorcha Platform — Environment Configuration
# =============================================================================
#
# Copy this file to .env and edit the values for your environment.
# Run ./scripts/sorcha-setup.sh for interactive setup that generates this file.
#
# NEVER commit .env to source control — it contains secrets.
# The .env file is already in .gitignore.
#
# Variables marked [REQUIRED] must be set. Others have sensible defaults.
# Variables marked [SECRET] should use strong random values in production.
#

# =============================================================================
# Installation Identity
# =============================================================================

# Display name for this Sorcha node. Used in JWT issuer URLs and peer identity.
# For local development, "localhost" is fine. In production, use your domain.
INSTALLATION_NAME=localhost

# =============================================================================
# JWT Authentication                                                  [SECRET]
# =============================================================================

# 256-bit base64-encoded key used to sign all JWT tokens.
# CRITICAL: Generate a unique key for every deployment.
# Generate with: openssl rand -base64 32
# Default below is for development only — CHANGE IN PRODUCTION.
JWT_SIGNING_KEY=c29yY2hhLWRvY2tlci1kZXYta2V5LTIwMjUtbWluLTI1Ni1iaXRzLXNlY3VyZQ==

# =============================================================================
# PostgreSQL Database                                                 [SECRET]
# =============================================================================

# Credentials for PostgreSQL (used by Tenant Service and Wallet Service).
# The docker-compose stack creates the database with these credentials.
POSTGRES_USER=sorcha
POSTGRES_PASSWORD=sorcha_dev_password

# Override the default PostgreSQL port if 5432 is already in use.
# POSTGRES_PORT=5432

# =============================================================================
# MongoDB Database                                                    [SECRET]
# =============================================================================

# Credentials for MongoDB (used by Register Service for ledger storage).
# The docker-compose stack creates the database with these credentials.
MONGO_USERNAME=sorcha
MONGO_PASSWORD=sorcha_dev_password

# Override the default MongoDB port if 27017 is already in use.
# MONGODB_PORT=27017

# =============================================================================
# Redis
# =============================================================================

# Redis password. Leave empty for no authentication (development only).
# In production, set a strong password.
REDIS_PASSWORD=

# Override the default Redis port if 6379 is already in use.
# REDIS_PORT=16379

# =============================================================================
# Runtime Environment
# =============================================================================

# ASP.NET Core environment: Development, Staging, or Production.
# Development enables detailed errors, Scalar API docs, and seed data.
ASPNETCORE_ENVIRONMENT=Development

# =============================================================================
# AI Integration (Optional)
# =============================================================================

# Anthropic API key for AI-assisted blueprint design chat.
# Leave empty to disable AI features. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# =============================================================================
# Peer Network (Optional)
# =============================================================================

# Unique node ID for this Sorcha instance in the peer network.
# Format: <name>.sorcha.dev (or your domain)
PEER_NODE_ID=local-peer.sorcha.dev

# Public address for incoming peer connections (empty = not publicly reachable).
# PEER_PUBLIC_ADDRESS=

# Seed peer to connect to on startup (for joining an existing network).
# Leave empty for standalone operation.
# SEED_PEER_NODE_ID=
# SEED_PEER_HOST=
# SEED_PEER_PORT=50051

# =============================================================================
# Port Overrides (Optional)
# =============================================================================
# Override default ports if they conflict with other services on your machine.
# Defaults are shown in comments. Uncomment and change as needed.
#
# GATEWAY_HTTP_PORT=80         # API Gateway HTTP
# GATEWAY_HTTPS_PORT=443       # API Gateway HTTPS
# BLUEPRINT_PORT=5000          # Blueprint Service
# REGISTER_PORT=5380           # Register Service
# TENANT_PORT=5450             # Tenant Service
# VALIDATOR_HTTP_PORT=5800     # Validator Service HTTP
# VALIDATOR_GRPC_PORT=5801     # Validator Service gRPC
# UI_HTTP_PORT=5400            # Sorcha UI HTTP
# UI_HTTPS_PORT=5401           # Sorcha UI HTTPS
# PEER_GRPC_PORT=50051         # Peer Service gRPC
# ASPIRE_UI_PORT=18888         # Aspire Dashboard
