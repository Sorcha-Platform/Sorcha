@inherits LayoutComponentBase
@inject IConfiguration Configuration

<div class="auth-layout">
    <div class="auth-container">
        @Body
    </div>
    @if (!RequireOpenApiAuth)
    {
        <div class="auth-footer">
            <a href="/openapi" target="_blank">API Documentation</a>
            <span class="separator">|</span>
            <a href="https://github.com/sorcha-platform/sorcha/tree/master/docs" target="_blank">Developer Docs</a>
        </div>
    }
</div>

@code {
    private bool RequireOpenApiAuth =>
        Configuration.GetValue<bool>("OpenApi:RequireAuth", true);
}

<style>
    .auth-layout {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        padding: 2rem;
    }

    .auth-container {
        width: 100%;
        max-width: 450px;
    }

    .auth-footer {
        text-align: center;
        margin-top: 1.5rem;
        font-size: 0.875rem;
    }

    .auth-footer a {
        color: #6366f1;
        text-decoration: none;
    }

    .auth-footer a:hover {
        text-decoration: underline;
    }

    .auth-footer .separator {
        margin: 0 0.5rem;
        color: #94a3b8;
    }
</style>
