@inherits LayoutComponentBase
@implements IAsyncDisposable
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor
@using Sorcha.UI.Core.Services.Authentication
@using Sorcha.UI.Core.Services
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject ITokenRefreshService TokenRefreshService
@inject IActivityLogService ActivityLogService
@inject IThemeService ThemeService
@inject IJSRuntime JSRuntime
@inject EventsHubConnection EventsHub
@inject ILocalizationService Loc

<MudThemeProvider Theme="_theme" IsDarkMode="@_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<CascadingAuthenticationState>
<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h5" Class="ml-3" Style="cursor: pointer;" @onclick="@(() => Navigation.NavigateTo("dashboard"))">Sorcha</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit" OnClick="@ToggleActivityLog" Title="Activity Log">
                    @if (_unreadCount > 0)
                    {
                        <MudBadge Content="@_unreadCount" Color="Color.Error" Overlap="true" />
                    }
                </MudIconButton>
                <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                    <MudMenuItem>
                        <div class="d-flex flex-column py-2 px-3">
                            <MudText Typo="Typo.body2" Color="Color.Primary">@context.User.Identity?.Name</MudText>
                            <MudText Typo="Typo.caption" Class="mt-1">@GetUserRole(context)</MudText>
                        </div>
                    </MudMenuItem>
                    <MudDivider />
                    <MudMenuItem Icon="@Icons.Material.Filled.Settings" OnClick="@(() => Navigation.NavigateTo("settings"))">
                        @Loc.T("nav.settings")
                    </MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="@HandleLogout">
                        @Loc.T("nav.logout")
                    </MudMenuItem>
                </MudMenu>
            </Authorized>
            <NotAuthorized>
                <MudButton OnClick="@(() => Navigation.NavigateTo("/auth/login", forceLoad: true))" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Login">
                    @Loc.T("nav.signIn")
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Variant="@DrawerVariant.Mini" OpenMiniOnHover="true" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudDrawerHeader>
            @if (_drawerOpen)
            {
                <MudText Typo="Typo.h6">@Loc.T("nav.navigation")</MudText>
            }
        </MudDrawerHeader>
        <AuthorizeView>
            <Authorized>
                <MudNavMenu>
                    <MudNavLink Href="dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">
                        @Loc.T("nav.dashboard")
                    </MudNavLink>
                    @if (_drawerOpen)
                    {
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.overline" Class="px-4 mud-text-secondary">@Loc.T("nav.section.myActivity")</MudText>
                    }
                    <MudNavLink Href="my-workflows" Icon="@Icons.Material.Filled.PostAdd">
                        @Loc.T("nav.newSubmission")
                    </MudNavLink>
                    <MudNavLink Href="my-actions" Icon="@Icons.Material.Filled.Task">
                        @Loc.T("nav.pendingActions")
                    </MudNavLink>
                    <MudNavLink Href="wallets" Icon="@Icons.Material.Filled.AccountBalanceWallet">
                        @Loc.T("nav.myWallet")
                    </MudNavLink>
                    <MudNavLink Href="credentials" Icon="@Icons.Material.Filled.Badge">
                        @Loc.T("nav.myCredentials")
                    </MudNavLink>
                    <MudNavLink Href="my-transactions" Icon="@Icons.Material.Filled.Receipt">
                        @Loc.T("nav.myTransactions")
                    </MudNavLink>
                    <MudNavLink Href="operations" Icon="@Icons.Material.Filled.Lock">
                        @Loc.T("nav.encryptionOperations")
                    </MudNavLink>
                    @if (_drawerOpen)
                    {
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.overline" Class="px-4 mud-text-secondary">@Loc.T("nav.section.designer")</MudText>
                    }
                    <MudNavLink Href="blueprints" Icon="@Icons.Material.Filled.Description">
                        @Loc.T("nav.myBlueprints")
                    </MudNavLink>
                    <MudNavLink Href="designer" Icon="@Icons.Material.Filled.Add">
                        @Loc.T("nav.visualDesigner")
                    </MudNavLink>
                    <MudNavLink Href="designer/chat" Icon="@Icons.Material.Filled.SmartToy">
                        @Loc.T("nav.aiChatDesigner")
                    </MudNavLink>
                    <MudNavLink Href="templates" Icon="@Icons.Material.Filled.ContentCopy">
                        @Loc.T("nav.catalogue")
                    </MudNavLink>
                    <MudNavLink Href="schemas" Icon="@Icons.Material.Filled.Schema">
                        @Loc.T("nav.dataSchemas")
                    </MudNavLink>
                    @if (_drawerOpen)
                    {
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.overline" Class="px-4 mud-text-secondary">@Loc.T("nav.section.administration")</MudText>
                    }
                    <MudNavGroup Title="@Loc.T("nav.wallets")" Icon="@Icons.Material.Filled.AccountBalanceWallet" Expanded="false">
                        <MudNavLink Href="wallet-admin" Icon="@Icons.Material.Filled.List">
                            @Loc.T("nav.allWallets")
                        </MudNavLink>
                        <MudNavLink Href="wallets/create" Icon="@Icons.Material.Filled.AddCircleOutline">
                            @Loc.T("nav.createWallet")
                        </MudNavLink>
                        <MudNavLink Href="wallets/recover" Icon="@Icons.Material.Filled.Restore">
                            @Loc.T("nav.recoverWallet")
                        </MudNavLink>
                    </MudNavGroup>
                    <MudNavLink Href="registers" Icon="@Icons.Material.Filled.Storage">
                        @Loc.T("nav.registers")
                    </MudNavLink>
                    <MudNavLink Href="participants" Icon="@Icons.Material.Filled.People">
                        @Loc.T("nav.participants")
                    </MudNavLink>
                    <AuthorizeView Roles="Administrator,SystemAdmin">
                        <Authorized Context="adminContext">
                            <MudNavGroup Title="Identity" Icon="@Icons.Material.Filled.Security" Expanded="false">
                                <MudNavLink Href="admin/identity" Icon="@Icons.Material.Filled.Dashboard">
                                    Dashboard
                                </MudNavLink>
                                <MudNavLink Href="admin/identity/users" Icon="@Icons.Material.Filled.People">
                                    Users
                                </MudNavLink>
                                <MudNavLink Href="admin/identity/idp" Icon="@Icons.Material.Filled.Key">
                                    Identity Providers
                                </MudNavLink>
                                <MudNavLink Href="admin/identity/invitations" Icon="@Icons.Material.Filled.Email">
                                    Invitations
                                </MudNavLink>
                                <MudNavLink Href="admin/identity/domains" Icon="@Icons.Material.Filled.Domain">
                                    Domain Restrictions
                                </MudNavLink>
                                <MudNavLink Href="admin/identity/audit" Icon="@Icons.Material.Filled.History">
                                    Audit Log
                                </MudNavLink>
                                <MudNavLink Href="admin/settings/organization" Icon="@Icons.Material.Filled.Settings">
                                    Org Settings
                                </MudNavLink>
                            </MudNavGroup>
                            <MudNavGroup Title="System" Icon="@Icons.Material.Filled.AdminPanelSettings" Expanded="false">
                                <MudNavLink Href="admin/health" Icon="@Icons.Material.Filled.HealthAndSafety">
                                    @Loc.T("nav.systemHealth")
                                </MudNavLink>
                                <MudNavLink Href="admin/peers" Icon="@Icons.Material.Filled.Hub">
                                    @Loc.T("nav.peerNetwork")
                                </MudNavLink>
                                <MudNavLink Href="admin/organizations" Icon="@Icons.Material.Filled.Business">
                                    @Loc.T("nav.organizations")
                                </MudNavLink>
                                <MudNavLink Href="admin/validator" Icon="@Icons.Material.Filled.VerifiedUser">
                                    @Loc.T("nav.validator")
                                </MudNavLink>
                                <MudNavLink Href="admin/principals" Icon="@Icons.Material.Filled.VpnKey">
                                    @Loc.T("nav.servicePrincipals")
                                </MudNavLink>
                                <MudNavLink Href="admin/sectors" Icon="@Icons.Material.Filled.FilterList">
                                    @Loc.T("nav.schemaSectors")
                                </MudNavLink>
                                <MudNavLink Href="admin/schema-providers" Icon="@Icons.Material.Filled.CloudSync">
                                    @Loc.T("nav.schemaProviders")
                                </MudNavLink>
                                <MudNavLink Href="admin/events" Icon="@Icons.Material.Filled.Event">
                                    Events
                                </MudNavLink>
                                <MudNavLink Href="admin/system-register" Icon="@Icons.Material.Filled.Storage">
                                    System Register
                                </MudNavLink>
                                <MudNavLink Href="admin/status-lists" Icon="@Icons.Material.Filled.Checklist">
                                    Status Lists
                                </MudNavLink>
                                <MudNavLink Href="admin/presentations" Icon="@Icons.Material.Filled.QrCode2">
                                    Presentations
                                </MudNavLink>
                            </MudNavGroup>
                        </Authorized>
                    </AuthorizeView>
                    @if (_drawerOpen)
                    {
                        <MudDivider Class="my-2" />
                    }
                    <MudNavLink Href="settings" Icon="@Icons.Material.Filled.Settings">
                        @Loc.T("nav.settings")
                    </MudNavLink>
                    <MudNavLink Href="settings/notifications" Icon="@Icons.Material.Filled.Notifications">
                        Notifications
                    </MudNavLink>
                    <MudNavLink Href="help" Icon="@Icons.Material.Filled.Help">
                        @Loc.T("nav.help")
                    </MudNavLink>
                </MudNavMenu>
            </Authorized>
            <NotAuthorized>
                <MudNavMenu>
                    <MudNavLink OnClick="@(() => Navigation.NavigateTo("/auth/login", forceLoad: true))" Icon="@Icons.Material.Filled.Login">
                        @Loc.T("nav.signIn")
                    </MudNavLink>
                </MudNavMenu>
            </NotAuthorized>
        </AuthorizeView>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-4" Style="padding-bottom: 40px;">
            @Body
        </MudContainer>
    </MudMainContent>
    <StatusFooter />
    <ActivityLogPanel @bind-IsOpen="_activityLogOpen" OnEventsRead="RefreshUnreadCount" />
    <OperationNotificationListener />
</MudLayout>

</CascadingAuthenticationState>

@code {
    private bool _drawerOpen = true;
    private bool _tokenRefreshStarted;
    private bool _activityLogOpen;
    private int _unreadCount;
    private bool _isDarkMode;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_tokenRefreshStarted)
        {
            _tokenRefreshStarted = true;
            await TokenRefreshService.StartAsync(JSRuntime);
            await RefreshUnreadCount();

            ThemeService.OnThemeChanged += OnThemeChanged;
            await ThemeService.InitializeAsync();
            _isDarkMode = ThemeService.IsDarkMode;

            Loc.OnLanguageChanged += OnLanguageChanged;
            await Loc.InitializeAsync();

            EventsHub.OnUnreadCountUpdated += OnUnreadCountUpdated;
            try
            {
                await EventsHub.ConnectAsync();
            }
            catch (Exception)
            {
                // Hub may be unavailable — SignalR will auto-reconnect
            }

            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        ThemeService.OnThemeChanged -= OnThemeChanged;
        Loc.OnLanguageChanged -= OnLanguageChanged;
        EventsHub.OnUnreadCountUpdated -= OnUnreadCountUpdated;
        await EventsHub.DisconnectAsync();
        await TokenRefreshService.StopAsync();
    }

    private void OnThemeChanged()
    {
        _isDarkMode = ThemeService.IsDarkMode;
        InvokeAsync(StateHasChanged);
    }

    private void OnLanguageChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnUnreadCountUpdated(int count)
    {
        _unreadCount = count;
        InvokeAsync(StateHasChanged);
    }

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#667eea",
            Secondary = "#764ba2",
            AppbarBackground = "#667eea",
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#667eea",
            Secondary = "#764ba2",
            AppbarBackground = "#1e1e1e",
            Surface = "#1e1e1e",
            Background = "#121212",
            DrawerBackground = "#1e1e1e",
            TextPrimary = "#e0e0e0",
            TextSecondary = "#b0b0b0",
            LinesDefault = "#333333",
        }
    };

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private string GetUserRole(AuthenticationState authState)
    {
        var roleClaim = authState.User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role);
        return roleClaim?.Value ?? "User";
    }

    private void HandleLogout()
    {
        // Navigate to logout page using relative path
        Navigation.NavigateTo("auth/logout", forceLoad: false);
    }

    private void ToggleActivityLog()
    {
        _activityLogOpen = !_activityLogOpen;
    }

    private async Task RefreshUnreadCount()
    {
        try
        {
            _unreadCount = await ActivityLogService.GetUnreadCountAsync();
            StateHasChanged();
        }
        catch (Exception)
        {
            // Resilience: unread count is a non-critical UI element -- don't fail the layout
        }
    }
}
