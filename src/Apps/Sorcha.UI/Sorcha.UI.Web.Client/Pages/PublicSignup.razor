@page "/auth/public/signup"
@layout AuthLayout
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using System.Net.Http.Json
@using System.Text.Json
@using Sorcha.UI.Core.Models.Authentication
@using Sorcha.UI.Core.Models.Configuration
@using Sorcha.UI.Core.Services.Authentication
@using Sorcha.UI.Core.Services.Configuration
@using Sorcha.UI.Core.Services.Navigation
@using Sorcha.UI.Web.Client.Components.Layout
@using Sorcha.UI.Web.Client.Services
@inject IAuthenticationService AuthService
@inject IConfigurationService ConfigService
@inject INavigationService NavigationService
@inject CustomAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject HttpClient Http
@inject PasskeyInteropService PasskeyInterop

<PageTitle>Sign Up - Sorcha</PageTitle>

<div class="signup-card">
    <div class="signup-header">
        <h2 class="signup-title">Create Account</h2>
        <p class="signup-subtitle">Get started with Sorcha</p>
    </div>

    <div class="signup-body">
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @_errorMessage
                <button type="button" class="btn-close" @onclick="@(() => _errorMessage = "")"></button>
            </div>
        }

        @if (!string.IsNullOrEmpty(_successMessage))
        {
            <div class="alert alert-success">@_successMessage</div>
        }

        @if (_currentStep == SignupStep.MethodSelection)
        {
            @* Step 1: Choose signup method *@
            <div class="method-section">
                @if (_webAuthnSupported)
                {
                    <button class="btn btn-primary w-100 btn-lg passkey-btn mb-3"
                            @onclick="SelectPasskeyMethod"
                            disabled="@_isProcessing">
                        <span class="passkey-icon me-2">&#128273;</span>
                        <span>Sign up with Passkey</span>
                    </button>
                }

                <div class="divider-row">
                    <hr class="divider-line" />
                    <span class="divider-text">or continue with</span>
                    <hr class="divider-line" />
                </div>

                <div class="social-buttons">
                    <button class="btn btn-outline-secondary w-100 social-btn mb-2"
                            @onclick='@(() => HandleSocialSignup("Google"))'
                            disabled="@_isProcessing">
                        <span class="social-icon me-2">G</span>
                        <span>Google</span>
                    </button>

                    <button class="btn btn-outline-secondary w-100 social-btn mb-2"
                            @onclick='@(() => HandleSocialSignup("Microsoft"))'
                            disabled="@_isProcessing">
                        <span class="social-icon me-2">M</span>
                        <span>Microsoft</span>
                    </button>

                    <button class="btn btn-outline-secondary w-100 social-btn mb-2"
                            @onclick='@(() => HandleSocialSignup("GitHub"))'
                            disabled="@_isProcessing">
                        <span class="social-icon me-2">&#128025;</span>
                        <span>GitHub</span>
                    </button>

                    <button class="btn btn-outline-secondary w-100 social-btn mb-2"
                            @onclick='@(() => HandleSocialSignup("Apple"))'
                            disabled="@_isProcessing">
                        <span class="social-icon me-2">&#63743;</span>
                        <span>Apple</span>
                    </button>
                </div>

                @if (!_webAuthnSupported)
                {
                    <div class="alert alert-info mt-3 small">
                        Passkey signup is not available in this browser. Use a social provider or try a modern browser.
                    </div>
                }
            </div>
        }
        else if (_currentStep == SignupStep.PasskeyForm)
        {
            @* Step 2: Collect name and email for passkey registration *@
            <div class="passkey-form-section">
                <h5 class="mb-3">Passkey Registration</h5>
                <p class="text-muted mb-4">Enter your details to create an account with a passkey.</p>

                <div class="mb-3">
                    <label class="form-label">Display Name</label>
                    <input type="text"
                           class="form-control"
                           @bind="_displayName"
                           @onkeydown="HandlePasskeyFormKeyDown"
                           placeholder="Your name"
                           autocomplete="name" />
                </div>

                <div class="mb-4">
                    <label class="form-label">Email <span class="text-muted">(optional)</span></label>
                    <input type="email"
                           class="form-control"
                           @bind="_email"
                           @onkeydown="HandlePasskeyFormKeyDown"
                           placeholder="you@example.com"
                           autocomplete="email" />
                    <small class="form-text text-muted">
                        Used for account recovery and notifications.
                    </small>
                </div>

                <button class="btn btn-primary w-100 btn-lg passkey-btn"
                        @onclick="HandlePasskeyRegistration"
                        disabled="@(_isProcessing || string.IsNullOrWhiteSpace(_displayName))">
                    @if (_isProcessing)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Creating passkey...</span>
                    }
                    else
                    {
                        <span class="passkey-icon me-2">&#128273;</span>
                        <span>Create Passkey</span>
                    }
                </button>

                <div class="text-center mt-3">
                    <button class="btn btn-link text-decoration-none" @onclick="BackToMethodSelection">
                        Back to signup options
                    </button>
                </div>
            </div>
        }

        <div class="text-center mt-3">
            <a href="/auth/login" class="text-decoration-none">
                Already have an account? Sign in
            </a>
        </div>
    </div>
</div>

<style>
    .signup-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
        overflow: hidden;
        max-width: 480px;
        margin: 0 auto;
    }

    .signup-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 2rem;
        text-align: center;
    }

    .signup-title {
        font-size: 2rem;
        font-weight: 600;
        margin: 0 0 0.5rem 0;
    }

    .signup-subtitle {
        margin: 0;
        opacity: 0.9;
        font-size: 1rem;
    }

    .signup-body {
        padding: 2rem;
    }

    .signup-card .form-label {
        font-weight: 500;
        margin-bottom: 0.5rem;
    }

    .signup-card .form-control {
        padding: 0.75rem 1rem;
        font-size: 1rem;
    }

    .signup-card .btn-primary {
        padding: 0.75rem;
        font-size: 1.1rem;
        font-weight: 500;
    }

    .passkey-btn {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .passkey-icon {
        font-size: 1.2rem;
    }

    .divider-row {
        display: flex;
        align-items: center;
        margin: 1.5rem 0;
    }

    .divider-line {
        flex: 1;
        border: none;
        border-top: 1px solid #dee2e6;
        margin: 0;
    }

    .divider-text {
        padding: 0 1rem;
        color: #6c757d;
        font-size: 0.9rem;
        white-space: nowrap;
    }

    .social-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0.65rem 1rem;
        font-size: 1rem;
        font-weight: 500;
    }

    .social-icon {
        font-size: 1.1rem;
        font-weight: 700;
    }

    .passkey-form-section h5 {
        font-weight: 600;
        color: #333;
    }
</style>

@code {
    private enum SignupStep
    {
        MethodSelection,
        PasskeyForm
    }

    private SignupStep _currentStep = SignupStep.MethodSelection;
    private bool _webAuthnSupported;
    private bool _isProcessing;
    private string _errorMessage = "";
    private string _successMessage = "";

    // Passkey form fields
    private string _displayName = "";
    private string _email = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _webAuthnSupported = await PasskeyInterop.IsWebAuthnSupportedAsync();
                StateHasChanged();
            }
            catch (JSException)
            {
                _webAuthnSupported = false;
            }
        }
    }

    /// <summary>
    /// Handles Enter key in passkey form fields.
    /// </summary>
    private async Task HandlePasskeyFormKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_isProcessing && !string.IsNullOrWhiteSpace(_displayName))
        {
            await HandlePasskeyRegistration();
        }
    }

    /// <summary>
    /// Navigates to the passkey registration form.
    /// </summary>
    private void SelectPasskeyMethod()
    {
        _errorMessage = "";
        _currentStep = SignupStep.PasskeyForm;
    }

    /// <summary>
    /// Returns to the method selection step.
    /// </summary>
    private void BackToMethodSelection()
    {
        _errorMessage = "";
        _currentStep = SignupStep.MethodSelection;
    }

    /// <summary>
    /// Handles passkey registration ceremony for public signup.
    /// </summary>
    private async Task HandlePasskeyRegistration()
    {
        _errorMessage = "";
        _isProcessing = true;

        try
        {
            // Step 1: Request registration options from server
            var optionsPayload = new
            {
                display_name = _displayName.Trim(),
                email = string.IsNullOrWhiteSpace(_email) ? (string?)null : _email.Trim()
            };

            var optionsResponse = await Http.PostAsJsonAsync("/api/auth/public/passkey/register/options", optionsPayload);

            if (!optionsResponse.IsSuccessStatusCode)
            {
                var errorBody = await optionsResponse.Content.ReadAsStringAsync();
                if (optionsResponse.StatusCode == System.Net.HttpStatusCode.Conflict)
                {
                    _errorMessage = "An account with this email already exists. Please sign in instead.";
                }
                else
                {
                    _errorMessage = "Failed to start passkey registration. Please try again.";
                }
                return;
            }

            var optionsJson = await optionsResponse.Content.ReadAsStringAsync();
            using var optionsDoc = JsonDocument.Parse(optionsJson);
            var transactionId = optionsDoc.RootElement.GetProperty("transaction_id").GetString()!;
            var creationOptions = optionsDoc.RootElement.GetProperty("options");

            // Step 2: Trigger browser WebAuthn credential creation
            var attestationResponse = await PasskeyInterop.CreateCredentialAsync(creationOptions);

            // Step 3: Verify registration with server
            var verifyPayload = new
            {
                transaction_id = transactionId,
                attestation_response = attestationResponse
            };

            var verifyResponse = await Http.PostAsJsonAsync("/api/auth/public/passkey/register/verify", verifyPayload);

            if (!verifyResponse.IsSuccessStatusCode)
            {
                _errorMessage = "Passkey registration verification failed. Please try again.";
                return;
            }

            var tokenResponse = await verifyResponse.Content.ReadFromJsonAsync<TokenResponse>();
            if (tokenResponse == null || !tokenResponse.IsValid())
            {
                _errorMessage = "Invalid token response from server.";
                return;
            }

            // Store tokens and complete signup
            var activeProfile = await ConfigService.GetActiveProfileNameAsync();
            await AuthService.StoreExternalTokenAsync(tokenResponse, activeProfile);

            // Give the token cache a moment to persist
            await Task.Delay(100);

            AuthStateProvider.NotifyAuthenticationStateChanged();
            await Task.Delay(100);

            NavigationService.NavigateToValidatedUrl(null, "dashboard");
        }
        catch (JSException ex)
        {
            if (ex.Message.Contains("NotAllowedError") || ex.Message.Contains("AbortError"))
            {
                _errorMessage = "Passkey creation was cancelled.";
            }
            else if (ex.Message.Contains("InvalidStateError"))
            {
                _errorMessage = "A passkey for this device already exists. Try signing in instead.";
            }
            else
            {
                _errorMessage = $"Passkey error: {ex.Message}";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            _isProcessing = false;
        }
    }

    /// <summary>
    /// Initiates social login signup flow for the given provider.
    /// </summary>
    private async Task HandleSocialSignup(string provider)
    {
        _errorMessage = "";
        _isProcessing = true;

        try
        {
            var redirectUri = $"{Navigation.BaseUri}auth/social/callback";

            var payload = new
            {
                provider = provider,
                redirect_uri = redirectUri
            };

            var response = await Http.PostAsJsonAsync("/api/auth/public/social/initiate", payload);

            if (!response.IsSuccessStatusCode)
            {
                _errorMessage = $"Failed to initiate {provider} sign-up. The provider may not be configured.";
                return;
            }

            var initiateJson = await response.Content.ReadAsStringAsync();
            using var doc = JsonDocument.Parse(initiateJson);
            var authorizationUrl = doc.RootElement.GetProperty("authorization_url").GetString();

            if (!string.IsNullOrEmpty(authorizationUrl))
            {
                // Redirect to the social provider's authorization page
                Navigation.NavigateTo(authorizationUrl, forceLoad: true);
            }
            else
            {
                _errorMessage = "Invalid authorization URL received from server.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            _isProcessing = false;
        }
    }
}
