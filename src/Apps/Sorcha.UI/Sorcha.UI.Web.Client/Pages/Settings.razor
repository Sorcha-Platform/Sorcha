@page "/settings"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@using Sorcha.UI.Core.Models
@using Sorcha.UI.Core.Models.Configuration
@using Sorcha.UI.Core.Services
@using Sorcha.UI.Core.Services.Configuration
@using Sorcha.UI.Core.Components.Configuration
@inject IUserPreferencesService PreferencesService
@inject IConfigurationService ConfigService
@inject ITotpClientService TotpService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject ILocalizationService Loc
@inject IThemeService ThemeService
@implements IDisposable

<PageTitle>@Loc.T("settings.pageTitle")</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2" />
        @Loc.T("settings.title")
    </MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
        @Loc.T("settings.subtitle")
    </MudText>

    <MudPaper Class="pa-4" Elevation="2">
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">

            <!-- Appearance Tab -->
            <MudTabPanel Text="@Loc.T("settings.appearance")" Icon="@Icons.Material.Filled.Palette">
                <MudText Typo="Typo.h6" Class="mb-3">@Loc.T("settings.theme")</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                    @Loc.T("settings.theme.description")
                </MudText>

                <MudRadioGroup T="string" Value="@_preferences.Theme" ValueChanged="OnThemeChanged">
                    <MudRadio T="string" Value="@("Light")" Color="Color.Primary">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.LightMode" Class="mr-2" />
                            @Loc.T("settings.theme.light")
                        </div>
                    </MudRadio>
                    <MudRadio T="string" Value="@("Dark")" Color="Color.Primary">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.DarkMode" Class="mr-2" />
                            @Loc.T("settings.theme.dark")
                        </div>
                    </MudRadio>
                    <MudRadio T="string" Value="@("System")" Color="Color.Primary">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.SettingsBrightness" Class="mr-2" />
                            @Loc.T("settings.theme.system")
                        </div>
                    </MudRadio>
                </MudRadioGroup>

                <MudDivider Class="my-4" />

                <MudText Typo="Typo.h6" Class="mb-3">@Loc.T("settings.timeFormat")</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                    @Loc.T("settings.timeFormat.description")
                </MudText>

                <MudRadioGroup T="string" Value="@_preferences.TimeFormat" ValueChanged="OnTimeFormatChanged">
                    <MudRadio T="string" Value="@("UTC")" Color="Color.Primary">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Public" Class="mr-2" />
                            @Loc.T("settings.timeFormat.utcDescription")
                        </div>
                    </MudRadio>
                    <MudRadio T="string" Value="@("Local")" Color="Color.Primary">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Class="mr-2" />
                            @Loc.T("settings.timeFormat.localDescription")
                        </div>
                    </MudRadio>
                </MudRadioGroup>
            </MudTabPanel>

            <!-- Language Tab -->
            <MudTabPanel Text="@Loc.T("settings.language")" Icon="@Icons.Material.Filled.Language">
                <MudText Typo="Typo.h6" Class="mb-3">@Loc.T("settings.language.title")</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                    @Loc.T("settings.language.description")
                </MudText>

                <MudList T="string" Dense="true" Class="mb-4" Style="max-width: 400px;">
                    @foreach (var lang in _supportedLanguages)
                    {
                        <MudListItem T="string"
                                     Icon="@(lang.Code == _preferences.Language ? Icons.Material.Filled.RadioButtonChecked : Icons.Material.Filled.RadioButtonUnchecked)"
                                     IconColor="@(lang.Code == _preferences.Language ? Color.Primary : Color.Default)"
                                     OnClick="@(() => OnLanguageChanged(lang.Code))">
                            <div class="d-flex align-center justify-space-between" style="width: 100%;">
                                <MudText>@lang.Name</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@lang.NativeName</MudText>
                            </div>
                        </MudListItem>
                    }
                </MudList>
            </MudTabPanel>

            <!-- Security Tab -->
            <MudTabPanel Text="@Loc.T("settings.security")" Icon="@Icons.Material.Filled.Security">
                <MudText Typo="Typo.h6" Class="mb-3">@Loc.T("settings.twoFactor.title")</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                    @Loc.T("settings.twoFactor.description")
                </MudText>

                @if (_preferences.TwoFactorEnabled)
                {
                    <MudAlert Severity="Severity.Success" Class="mb-4">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Class="mr-2" />
                            @Loc.T("settings.twoFactor.enabledMessage")
                        </div>
                    </MudAlert>

                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.RemoveCircle"
                               OnClick="DisableTwoFactor">
                        @Loc.T("settings.twoFactor.disable")
                    </MudButton>
                }
                else
                {
                    <MudAlert Severity="Severity.Warning" Class="mb-4">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Warning" Class="mr-2" />
                            @Loc.T("settings.twoFactor.disabledMessage")
                        </div>
                    </MudAlert>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Security"
                               OnClick="SetupTwoFactor">
                        @Loc.T("settings.twoFactor.enable")
                    </MudButton>
                }

                @if (_showTotpSetup)
                {
                    <MudDivider Class="my-4" />
                    <MudPaper Class="pa-4" Outlined="true">
                        <MudText Typo="Typo.subtitle1" Class="mb-3">@Loc.T("settings.twoFactor.setupTitle")</MudText>
                        <MudText Typo="Typo.body2" Class="mb-3">
                            @Loc.T("settings.twoFactor.setupDescription")
                        </MudText>

                        @if (!string.IsNullOrEmpty(_totpQrUri))
                        {
                            <div class="d-flex justify-center mb-4">
                                <div id="totp-qr-code" style="width: 200px; height: 200px; background: #f5f5f5; display: flex; align-items: center; justify-content: center;">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">QR Code</MudText>
                                </div>
                            </div>

                            <MudText Typo="Typo.caption" Class="mb-3" Align="Align.Center">
                                @Loc.T("settings.twoFactor.manualKey") <code>@_totpSecret</code>
                            </MudText>
                        }

                        <MudTextField @bind-Value="_totpVerificationCode"
                                      Label="@Loc.T("settings.twoFactor.verificationCodeLabel")"
                                      Placeholder="@Loc.T("settings.twoFactor.verificationCodePlaceholder")"
                                      Variant="Variant.Outlined"
                                      MaxLength="6"
                                      Style="max-width: 300px;"
                                      Class="mb-3" />

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="@(string.IsNullOrEmpty(_totpVerificationCode) || _totpVerificationCode.Length != 6)"
                                   OnClick="VerifyTotpSetup">
                            @Loc.T("settings.twoFactor.verifyAndEnable")
                        </MudButton>

                        @if (_totpBackupCodes.Any())
                        {
                            <MudDivider Class="my-4" />
                            <MudAlert Severity="Severity.Warning" Class="mb-3">
                                @Loc.T("settings.twoFactor.backupCodesWarning")
                            </MudAlert>
                            <MudPaper Class="pa-3" Outlined="true" Style="max-width: 300px;">
                                @foreach (var totpCode in _totpBackupCodes)
                                {
                                    <MudText Typo="Typo.body2" Style="font-family: monospace;">@totpCode</MudText>
                                }
                            </MudPaper>
                        }
                    </MudPaper>
                }
            </MudTabPanel>

            <!-- Notifications Tab -->
            <MudTabPanel Text="@Loc.T("settings.notifications")" Icon="@Icons.Material.Filled.Notifications">
                <MudText Typo="Typo.h6" Class="mb-3">@Loc.T("settings.notifications.push")</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                    @Loc.T("settings.notifications.description")
                </MudText>

                <MudSwitch T="bool" Value="@_preferences.NotificationsEnabled"
                           ValueChanged="OnNotificationsChanged"
                           Color="Color.Primary"
                           Label="@(_preferences.NotificationsEnabled ? Loc.T("settings.notifications.enabled") : Loc.T("settings.notifications.disabled"))" />

                @if (_preferences.NotificationsEnabled)
                {
                    <MudDivider Class="my-4" />
                    <MudText Typo="Typo.subtitle2" Class="mb-2">@Loc.T("settings.notifications.types")</MudText>
                    <MudCheckBox T="bool" Value="true" Disabled="true" Color="Color.Primary"
                                 Label="@Loc.T("settings.notifications.pendingActions")" />
                    <MudCheckBox T="bool" Value="true" Disabled="true" Color="Color.Primary"
                                 Label="@Loc.T("settings.notifications.workflowChanges")" />
                    <MudCheckBox T="bool" Value="true" Disabled="true" Color="Color.Primary"
                                 Label="@Loc.T("settings.notifications.validatorAlerts")" />
                }
            </MudTabPanel>

            <!-- Connections Tab (was Configuration) -->
            <MudTabPanel Text="@Loc.T("settings.connections")" Icon="@Icons.Material.Filled.Dns">
                <MudText Typo="Typo.h6" Class="mb-3">@Loc.T("settings.connections.title")</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                    @Loc.T("settings.connections.description")
                </MudText>

                <!-- Active Profile Display -->
                @if (_activeProfile != null)
                {
                    <MudAlert Severity="Severity.Info" Class="mb-4">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="mr-2" />
                            <div>
                                <strong>@Loc.T("settings.connections.activeProfile")</strong> @_activeProfile.Name
                                <br />
                                <MudText Typo="Typo.caption">
                                    @if (!string.IsNullOrEmpty(_activeProfile.SorchaServiceUrl))
                                    {
                                        <span>@Loc.T("settings.connections.baseUrl") @_activeProfile.SorchaServiceUrl</span>
                                    }
                                    else
                                    {
                                        <span>@Loc.T("settings.connections.usingIndividualUrls")</span>
                                    }
                                </MudText>
                            </div>
                        </div>
                    </MudAlert>
                }

                <!-- Profile List -->
                @if (_loading)
                {
                    <MudProgressLinear Indeterminate="true" Class="mb-4" />
                }
                else if (_profiles.Any())
                {
                    <MudTable Items="@_profiles.OrderBy(p => p.Name)" Hover="true" Breakpoint="Breakpoint.Sm" Dense="true" Class="mb-4">
                        <HeaderContent>
                            <MudTh>@Loc.T("settings.connections.profile")</MudTh>
                            <MudTh>@Loc.T("settings.connections.baseUrl")</MudTh>
                            <MudTh>@Loc.T("settings.connections.ssl")</MudTh>
                            <MudTh Style="width: 200px;">@Loc.T("settings.connections.actions")</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="@Loc.T("settings.connections.profile")">
                                <div class="d-flex align-center">
                                    <MudText>@context.Name</MudText>
                                    @if (context.Name == _activeProfile?.Name)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Class="ml-2">@Loc.T("settings.connections.active")</MudChip>
                                    }
                                    @if (context.IsSystemProfile)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="ml-1">@Loc.T("settings.connections.system")</MudChip>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(context.Description))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Description</MudText>
                                }
                            </MudTd>
                            <MudTd DataLabel="@Loc.T("settings.connections.baseUrl")">
                                <MudText Typo="Typo.body2">
                                    @(string.IsNullOrEmpty(context.SorchaServiceUrl) ? Loc.T("settings.connections.individualUrls") : context.SorchaServiceUrl)
                                </MudText>
                            </MudTd>
                            <MudTd DataLabel="@Loc.T("settings.connections.ssl")">
                                <MudIcon Icon="@(context.VerifySsl ? Icons.Material.Filled.Lock : Icons.Material.Filled.LockOpen)"
                                         Color="@(context.VerifySsl ? Color.Success : Color.Warning)"
                                         Size="Size.Small" />
                            </MudTd>
                            <MudTd DataLabel="@Loc.T("settings.connections.actions")">
                                @if (context.Name != _activeProfile?.Name)
                                {
                                    <MudButton Size="Size.Small"
                                               Variant="Variant.Text"
                                               Color="Color.Primary"
                                               OnClick="@(() => ActivateProfile(context.Name))">
                                        @Loc.T("settings.connections.activate")
                                    </MudButton>
                                }
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               Size="Size.Small"
                                               OnClick="@(() => EditProfile(context))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               Disabled="@(context.IsSystemProfile || context.Name == _activeProfile?.Name)"
                                               OnClick="@(() => DeleteProfile(context))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Class="mb-4">@Loc.T("settings.connections.noProfiles")</MudAlert>
                }

                <MudButton StartIcon="@Icons.Material.Filled.Add"
                           Color="Color.Primary"
                           Variant="Variant.Filled"
                           OnClick="CreateNewProfile">
                    @Loc.T("settings.connections.newProfile")
                </MudButton>
            </MudTabPanel>

            <!-- About Tab -->
            <MudTabPanel Text="@Loc.T("settings.about")" Icon="@Icons.Material.Filled.Info">
                <MudText Typo="Typo.h5" Class="mb-2">@Loc.T("settings.about.title")</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                    @Loc.T("settings.about.description")
                </MudText>

                <MudDivider Class="my-4" />

                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudPaper Class="pa-4" Outlined="true">
                            <MudText Typo="Typo.subtitle1" Class="mb-3">
                                <MudIcon Icon="@Icons.Material.Filled.Code" Size="Size.Small" Class="mr-1" />
                                @Loc.T("settings.about.versionInfo")
                            </MudText>
                            <MudText Typo="Typo.body2" Class="mb-1">
                                <strong>@Loc.T("settings.about.version")</strong> 1.0.0-preview
                            </MudText>
                            <MudText Typo="Typo.body2" Class="mb-1">
                                <strong>@Loc.T("settings.about.build")</strong> @_buildNumber
                            </MudText>
                            <MudText Typo="Typo.body2" Class="mb-1">
                                <strong>@Loc.T("settings.about.framework")</strong> .NET 10.0
                            </MudText>
                            <MudText Typo="Typo.body2">
                                <strong>@Loc.T("settings.about.platform")</strong> Blazor WebAssembly
                            </MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudPaper Class="pa-4" Outlined="true">
                            <MudText Typo="Typo.subtitle1" Class="mb-3">
                                <MudIcon Icon="@Icons.Material.Filled.Security" Size="Size.Small" Class="mr-1" />
                                @Loc.T("settings.about.securityFeatures")
                            </MudText>
                            <MudText Typo="Typo.body2" Class="mb-1">
                                <strong>@Loc.T("settings.about.cryptography")</strong> ED25519, P-256, RSA-4096
                            </MudText>
                            <MudText Typo="Typo.body2" Class="mb-1">
                                <strong>@Loc.T("settings.about.hdWallets")</strong> BIP32/BIP39/BIP44
                            </MudText>
                            <MudText Typo="Typo.body2" Class="mb-1">
                                <strong>@Loc.T("settings.about.authentication")</strong> JWT Bearer
                            </MudText>
                            <MudText Typo="Typo.body2">
                                <strong>@Loc.T("settings.about.model")</strong> DAD (Disclosure, Alteration, Destruction)
                            </MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-4" />

                <MudText Typo="Typo.subtitle1" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Link" Size="Size.Small" Class="mr-1" />
                    @Loc.T("settings.about.resources")
                </MudText>
                <MudGrid>
                    <MudItem xs="12" sm="4">
                        <MudButton Href="https://github.com/sorcha/platform"
                                   Target="_blank"
                                   Variant="Variant.Outlined"
                                   StartIcon="@Icons.Custom.Brands.GitHub"
                                   FullWidth="true">
                            @Loc.T("settings.about.github")
                        </MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudButton Href="help"
                                   Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.Help"
                                   FullWidth="true">
                            @Loc.T("settings.about.helpDocs")
                        </MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudButton Href="https://sorcha.io"
                                   Target="_blank"
                                   Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.Public"
                                   FullWidth="true">
                            @Loc.T("settings.about.website")
                        </MudButton>
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-4" />

                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @Loc.T("settings.about.license")
                </MudText>
            </MudTabPanel>
        </MudTabs>
    </MudPaper>
</MudContainer>

@code {
    private UserPreferencesDto _preferences = new();
    private List<Profile> _profiles = new();
    private Profile? _activeProfile;
    private bool _loading = true;
    private string _buildNumber = $"{DateTime.Now:yyyyMMdd}.{DateTime.Now:HHmm}";

    // TOTP setup state
    private bool _showTotpSetup;
    private string _totpSecret = string.Empty;
    private string _totpQrUri = string.Empty;
    private string _totpVerificationCode = string.Empty;
    private List<string> _totpBackupCodes = new();

    // Supported languages
    private readonly List<(string Code, string Name, string NativeName)> _supportedLanguages =
    [
        ("en", "English", "English"),
        ("fr", "French", "Français"),
        ("de", "German", "Deutsch"),
        ("es", "Spanish", "Español")
    ];

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += OnLocLanguageChanged;
        await Task.WhenAll(LoadPreferencesAsync(), LoadProfilesAsync());
    }

    private void OnLocLanguageChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Loc.OnLanguageChanged -= OnLocLanguageChanged;
    }

    private async Task LoadPreferencesAsync()
    {
        try
        {
            _preferences = await PreferencesService.GetUserPreferencesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{Loc.T("common.error")}: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnThemeChanged(string theme)
    {
        _preferences.Theme = theme;
        var themePreference = Enum.Parse<ThemePreference>(theme);
        await ThemeService.SetThemeAsync(themePreference);
        var themeKey = theme switch
        {
            "Light" => "settings.theme.light",
            "Dark" => "settings.theme.dark",
            _ => "settings.theme.system"
        };
        Snackbar.Add($"{Loc.T("settings.theme")}: {Loc.T(themeKey)}", Severity.Success);
    }

    private async Task OnTimeFormatChanged(string format)
    {
        _preferences.TimeFormat = format;
        await SavePreferencesAsync(new UpdateUserPreferencesRequest { TimeFormat = format });
        var formatKey = format == "UTC" ? "settings.timeFormat.utc" : "settings.timeFormat.local";
        Snackbar.Add($"{Loc.T("settings.timeFormat")}: {Loc.T(formatKey)}", Severity.Success);
    }

    private async Task OnLanguageChanged(string languageCode)
    {
        _preferences.Language = languageCode;
        await Loc.SetLanguageAsync(languageCode);
        var langName = _supportedLanguages.FirstOrDefault(l => l.Code == languageCode).Name ?? languageCode;
        Snackbar.Add($"{Loc.T("settings.language")}: {langName}", Severity.Success);
    }

    private async Task OnNotificationsChanged(bool enabled)
    {
        _preferences.NotificationsEnabled = enabled;
        await SavePreferencesAsync(new UpdateUserPreferencesRequest { NotificationsEnabled = enabled });
        Snackbar.Add(enabled ? Loc.T("settings.notifications.enabledSuccess") : Loc.T("settings.notifications.disabledSuccess"), Severity.Success);
    }

    private async Task SavePreferencesAsync(UpdateUserPreferencesRequest request)
    {
        try
        {
            _preferences = await PreferencesService.UpdateUserPreferencesAsync(request);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{Loc.T("common.error")}: {ex.Message}", Severity.Error);
        }
    }

    private async Task SetupTwoFactor()
    {
        try
        {
            var setupResponse = await TotpService.SetupTotpAsync();
            if (setupResponse != null)
            {
                _totpSecret = setupResponse.Secret;
                _totpQrUri = setupResponse.QrUri;
                _totpBackupCodes = setupResponse.BackupCodes?.ToList() ?? [];
                _showTotpSetup = true;
            }
            else
            {
                Snackbar.Add(Loc.T("settings.twoFactor.setupFailed"), Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{Loc.T("common.error")}: {ex.Message}", Severity.Error);
        }
    }

    private async Task VerifyTotpSetup()
    {
        if (string.IsNullOrEmpty(_totpVerificationCode) || _totpVerificationCode.Length != 6)
            return;

        try
        {
            var verified = await TotpService.VerifySetupAsync(_totpVerificationCode);
            if (verified)
            {
                _preferences.TwoFactorEnabled = true;
                _showTotpSetup = false;
                _totpVerificationCode = string.Empty;
                Snackbar.Add(Loc.T("settings.twoFactor.enabledSuccess"), Severity.Success);
            }
            else
            {
                Snackbar.Add(Loc.T("settings.twoFactor.invalidCode"), Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{Loc.T("common.error")}: {ex.Message}", Severity.Error);
        }
    }

    private async Task DisableTwoFactor()
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            Loc.T("settings.twoFactor.disableTitle"),
            Loc.T("settings.twoFactor.disableConfirm"),
            yesText: Loc.T("settings.twoFactor.disable"),
            cancelText: Loc.T("common.cancel"));

        if (confirmed == true)
        {
            try
            {
                var disabled = await TotpService.DisableTotpAsync();
                if (disabled)
                {
                    _preferences.TwoFactorEnabled = false;
                    _showTotpSetup = false;
                    _totpSecret = string.Empty;
                    _totpQrUri = string.Empty;
                    _totpBackupCodes.Clear();
                    Snackbar.Add(Loc.T("settings.twoFactor.disabledSuccess"), Severity.Info);
                }
                else
                {
                    Snackbar.Add(Loc.T("settings.twoFactor.disableFailed"), Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"{Loc.T("common.error")}: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task LoadProfilesAsync()
    {
        _loading = true;
        try
        {
            var profiles = await ConfigService.GetProfilesAsync();
            _profiles = profiles.ToList();
            _activeProfile = await ConfigService.GetActiveProfileAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{Loc.T("common.error")}: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ActivateProfile(string profileName)
    {
        try
        {
            await ConfigService.SetActiveProfileAsync(profileName);
            var profile = await ConfigService.GetProfileAsync(profileName);
            if (profile != null)
            {
                ApiConfiguration.ConfigureFromProfile(profile);
            }
            await LoadProfilesAsync();
            Snackbar.Add(Loc.T("settings.connections.activatedSuccess", profileName), Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{Loc.T("common.error")}: {ex.Message}", Severity.Error);
        }
    }

    private async Task EditProfile(Profile profile)
    {
        var parameters = new DialogParameters<ProfileEditorDialog>
        {
            { x => x.Profile, profile },
            { x => x.IsNew, false }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseButton = true
        };

        var dialog = await DialogService.ShowAsync<ProfileEditorDialog>(Loc.T("settings.connections.editProfile"), parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadProfilesAsync();
        }
    }

    private async Task CreateNewProfile()
    {
        var parameters = new DialogParameters<ProfileEditorDialog>
        {
            { x => x.Profile, null },
            { x => x.IsNew, true }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseButton = true
        };

        var dialog = await DialogService.ShowAsync<ProfileEditorDialog>(Loc.T("settings.connections.newProfile"), parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadProfilesAsync();
        }
    }

    private async Task DeleteProfile(Profile profile)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            Loc.T("settings.connections.deleteTitle"),
            Loc.T("settings.connections.deleteConfirm", profile.Name),
            yesText: Loc.T("common.delete"),
            cancelText: Loc.T("common.cancel"));

        if (confirmed == true)
        {
            try
            {
                var deleted = await ConfigService.DeleteProfileAsync(profile.Name);
                if (deleted)
                {
                    await LoadProfilesAsync();
                    Snackbar.Add(Loc.T("settings.connections.deletedSuccess", profile.Name), Severity.Info);
                }
                else
                {
                    Snackbar.Add(Loc.T("settings.connections.cannotDelete"), Severity.Warning);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"{Loc.T("common.error")}: {ex.Message}", Severity.Error);
            }
        }
    }
}
