@page "/admin/identity/domains"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@attribute [Authorize(Roles = "Administrator,SystemAdmin")]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Sorcha.UI.Core.Services.Identity

@inject IDomainRestrictionClientService DomainService
@inject ISnackbar Snackbar

<PageTitle>Domain Restrictions - Sorcha Platform</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-2 px-0" />
    <MudText Typo="Typo.h4" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Filled.Domain" Class="mr-2" />
        Domain Restrictions
    </MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
        Restrict auto-provisioning to specific email domains
    </MudText>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Class="mb-4" />
    }
    else
    {
        <MudPaper Class="pa-4" Elevation="2">
            <MudSwitch T="bool" @bind-Value="_restrictionsEnabled"
                       Label="Enable domain restrictions"
                       Color="Color.Primary" Class="mb-4" />

            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                @if (_restrictionsEnabled)
                {
                    <span>Only users with email addresses matching the listed domains can auto-provision via OIDC login.</span>
                }
                else
                {
                    <span>All email domains are allowed for OIDC auto-provisioning.</span>
                }
            </MudText>

            @if (_restrictionsEnabled)
            {
                <!-- Current domains -->
                <MudText Typo="Typo.subtitle2" Class="mb-2">Allowed Domains</MudText>
                <div class="mb-3">
                    @if (_domains.Count == 0)
                    {
                        <MudText Color="Color.Warning">No domains configured — all domains will be blocked.</MudText>
                    }
                    else
                    {
                        @foreach (var domain in _domains)
                        {
                            <MudChip T="string" Color="Color.Primary"
                                     OnClose="@(() => RemoveDomain(domain))"
                                     Class="mr-1 mb-1">
                                @domain
                            </MudChip>
                        }
                    }
                </div>

                <!-- Add domain -->
                <MudGrid>
                    <MudItem xs="12" sm="8">
                        <MudTextField @bind-Value="_newDomain"
                                      Label="Add Domain"
                                      Placeholder="example.com"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.AlternateEmail"
                                      OnKeyDown="OnDomainKeyDown" />
                    </MudItem>
                    <MudItem xs="12" sm="4" Class="d-flex align-end">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   OnClick="AddDomain"
                                   Disabled="@string.IsNullOrWhiteSpace(_newDomain)">
                            Add Domain
                        </MudButton>
                    </MudItem>
                </MudGrid>
            }

            <MudDivider Class="my-4" />
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="SaveAsync"
                       Disabled="_saving">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Save Changes
            </MudButton>
        </MudPaper>
    }
</MudContainer>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationState { get; set; }

    private readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Admin", href: "/admin/health"),
        new("Identity", href: "/admin/identity"),
        new("Domain Restrictions", href: null, disabled: true)
    ];

    private bool _loading = true;
    private bool _saving;
    private Guid _organizationId;
    private bool _restrictionsEnabled;
    private List<string> _domains = [];
    private string _newDomain = "";

    protected override async Task OnInitializedAsync()
    {
        if (AuthenticationState != null)
        {
            var authState = await AuthenticationState;
            var orgIdClaim = authState.User.Claims
                .FirstOrDefault(c => c.Type == "org_id" || c.Type == "organization_id");
            if (orgIdClaim != null && Guid.TryParse(orgIdClaim.Value, out var orgId))
                _organizationId = orgId;
        }

        if (_organizationId != Guid.Empty)
        {
            try
            {
                var restrictions = await DomainService.GetRestrictionsAsync(_organizationId);
                _domains = restrictions.AllowedDomains.ToList();
                _restrictionsEnabled = restrictions.RestrictionsActive;
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Failed to load restrictions: {ex.Message}", Severity.Error);
            }
        }

        _loading = false;
    }

    private void AddDomain()
    {
        var domain = _newDomain.Trim().ToLowerInvariant();
        if (!string.IsNullOrWhiteSpace(domain) && !_domains.Contains(domain))
        {
            _domains.Add(domain);
            _newDomain = "";
        }
    }

    private void OnDomainKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddDomain();
        }
    }

    private void RemoveDomain(string domain) => _domains.Remove(domain);

    private async Task SaveAsync()
    {
        _saving = true;
        try
        {
            var domainsToSave = _restrictionsEnabled ? _domains.ToArray() : [];
            var success = await DomainService.UpdateRestrictionsAsync(_organizationId, domainsToSave);
            Snackbar.Add(
                success ? "Domain restrictions saved" : "Failed to save domain restrictions",
                success ? Severity.Success : Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
