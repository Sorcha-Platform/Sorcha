@page "/admin/identity"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@attribute [Authorize(Roles = "Administrator,SystemAdmin")]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Sorcha.UI.Core.Services
@using Sorcha.UI.Core.Services.Identity

@inject IOrganizationAdminService OrgService
@inject IIdpConfigurationClientService IdpService
@inject IInvitationClientService InvitationService
@inject IAuditService AuditService

<PageTitle>Identity Dashboard - Sorcha Platform</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-2 px-0" />
    <MudText Typo="Typo.h4" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Filled.Security" Class="mr-2" />
        Identity Dashboard
    </MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
        Organization identity and access management overview
    </MudText>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Class="mb-4" />
    }
    else if (_error != null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
    }
    else
    {
        <!-- KPI Cards -->
        <MudGrid Class="mb-4">
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.overline">Active Users</MudText>
                    <MudText Typo="Typo.h4">@_activeUserCount</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.overline">Suspended Users</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Warning">@_suspendedUserCount</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.overline">Pending Invitations</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Info">@_pendingInvitationCount</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.overline">Active IDPs</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Success">@_activeIdpCount</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudGrid>
            <!-- Users by Role -->
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Users by Role</MudText>
                    <MudSimpleTable Hover="true" Dense="true">
                        <thead>
                            <tr><th>Role</th><th>Count</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var role in _usersByRole)
                            {
                                <tr><td>@role.Key</td><td>@role.Value</td></tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>
            </MudItem>

            <!-- Recent Logins -->
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Recent Logins</MudText>
                    @if (_recentLogins.Count == 0)
                    {
                        <MudText Color="Color.Secondary">No recent login events</MudText>
                    }
                    else
                    {
                        <MudSimpleTable Hover="true" Dense="true">
                            <thead>
                                <tr><th>Time</th><th>User</th><th>IP</th><th>Status</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var login in _recentLogins)
                                {
                                    <tr>
                                        <td>@login.Timestamp.LocalDateTime.ToString("g")</td>
                                        <td>@(login.IdentityId?.ToString("N")[..8] ?? "—")</td>
                                        <td>@(login.IpAddress ?? "—")</td>
                                        <td>
                                            <MudChip T="string" Size="Size.Small" Color="@(login.Success ? Color.Success : Color.Error)">
                                                @(login.Success ? "OK" : "Failed")
                                            </MudChip>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationState { get; set; }

    private readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Admin", href: "/admin/health"),
        new("Identity", href: null, disabled: true)
    ];

    private bool _loading = true;
    private string? _error;
    private int _activeUserCount;
    private int _suspendedUserCount;
    private int _pendingInvitationCount;
    private int _activeIdpCount;
    private Dictionary<string, int> _usersByRole = new();
    private List<AuditEventDto> _recentLogins = [];
    private Guid _organizationId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (AuthenticationState != null)
            {
                var authState = await AuthenticationState;
                var orgIdClaim = authState.User.Claims
                    .FirstOrDefault(c => c.Type == "org_id" || c.Type == "organization_id");
                if (orgIdClaim != null && Guid.TryParse(orgIdClaim.Value, out var orgId))
                {
                    _organizationId = orgId;
                }
            }

            if (_organizationId == Guid.Empty)
            {
                _error = "Organization context not available.";
                _loading = false;
                return;
            }

            // Load all data concurrently
            var usersTask = OrgService.GetOrganizationUsersAsync(_organizationId, includeInactive: true);
            var idpsTask = IdpService.GetIdpConfigurationsAsync(_organizationId);
            var invitationsTask = InvitationService.GetInvitationsAsync(_organizationId, "Pending");
            var loginsTask = AuditService.QueryAuditEventsAsync(_organizationId, eventType: "Login", pageSize: 10);

            await Task.WhenAll(usersTask, idpsTask, invitationsTask, loginsTask);

            var users = await usersTask;
            _activeUserCount = users.Users.Count(u => u.Status == "Active");
            _suspendedUserCount = users.Users.Count(u => u.Status == "Suspended");
            _usersByRole = users.Users
                .SelectMany(u => u.Roles)
                .GroupBy(r => r)
                .ToDictionary(g => g.Key, g => g.Count());

            var idps = await idpsTask;
            _activeIdpCount = idps.Count(i => i.IsEnabled);

            var invitations = await invitationsTask;
            _pendingInvitationCount = invitations.TotalCount;

            var logins = await loginsTask;
            _recentLogins = logins.Events.ToList();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load dashboard: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }
}
