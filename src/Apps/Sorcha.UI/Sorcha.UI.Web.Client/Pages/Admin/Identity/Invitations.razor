@page "/admin/identity/invitations"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@attribute [Authorize(Roles = "Administrator,SystemAdmin")]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Sorcha.UI.Core.Services.Identity

@inject IInvitationClientService InvitationService
@inject ISnackbar Snackbar

<PageTitle>Invitations - Sorcha Platform</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-2 px-0" />
    <MudText Typo="Typo.h4" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Filled.Email" Class="mr-2" />
        Invitations
    </MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
        Invite users to join your organization
    </MudText>

    <!-- Create Invitation -->
    <MudPaper Class="pa-4 mb-4" Elevation="2">
        <MudText Typo="Typo.h6" Class="mb-3">Send Invitation</MudText>
        <MudGrid>
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="_newEmail" Label="Email Address" Required="true" InputType="InputType.Email" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="string" @bind-Value="_newRole" Label="Role">
                    <MudSelectItem T="string" Value="@("Member")">Member</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Designer")">Designer</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Auditor")">Auditor</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Administrator")">Administrator</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudNumericField @bind-Value="_newExpiryDays" Label="Expires In (days)" Min="1" Max="30" />
            </MudItem>
            <MudItem xs="12" sm="2" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SendInvitationAsync"
                           Disabled="@string.IsNullOrWhiteSpace(_newEmail)" FullWidth="true">
                    Send
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <!-- Filter + List -->
    <MudPaper Class="pa-4" Elevation="2">
        <MudGrid Class="mb-3">
            <MudItem xs="12" sm="4">
                <MudSelect T="string" Value="_statusFilter" Label="Status Filter" ValueChanged="OnStatusFilterChanged">
                    <MudSelectItem T="string" Value="@((string?)null)">All</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Pending")">Pending</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Accepted")">Accepted</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Expired")">Expired</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Revoked")">Revoked</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else
        {
            <MudTable Items="_invitations" Hover="true" Striped="true" Dense="true">
                <HeaderContent>
                    <MudTh>Email</MudTh>
                    <MudTh>Role</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Expires</MudTh>
                    <MudTh>Sent</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Email</MudTd>
                    <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Primary">@context.AssignedRole</MudChip></MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">@context.Status</MudChip>
                    </MudTd>
                    <MudTd>@context.ExpiresAt.LocalDateTime.ToString("g")</MudTd>
                    <MudTd>@context.CreatedAt.LocalDateTime.ToString("g")</MudTd>
                    <MudTd>
                        @if (context.Status == "Pending")
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" Title="Resend"
                                           OnClick="@(async () => await ResendAsync(context.Id))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Color="Color.Error" Title="Revoke"
                                           OnClick="@(async () => await RevokeAsync(context.Id))" />
                        }
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        }
    </MudPaper>
</MudContainer>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationState { get; set; }

    private readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Admin", href: "/admin/health"),
        new("Identity", href: "/admin/identity"),
        new("Invitations", href: null, disabled: true)
    ];

    private bool _loading = true;
    private Guid _organizationId;
    private List<InvitationDto> _invitations = [];
    private string? _statusFilter;

    // New invitation form
    private string _newEmail = "";
    private string _newRole = "Member";
    private int _newExpiryDays = 7;

    protected override async Task OnInitializedAsync()
    {
        if (AuthenticationState != null)
        {
            var authState = await AuthenticationState;
            var orgIdClaim = authState.User.Claims
                .FirstOrDefault(c => c.Type == "org_id" || c.Type == "organization_id");
            if (orgIdClaim != null && Guid.TryParse(orgIdClaim.Value, out var orgId))
                _organizationId = orgId;
        }
        await LoadInvitationsAsync();
    }

    private async Task OnStatusFilterChanged(string? status)
    {
        _statusFilter = status;
        await LoadInvitationsAsync();
    }

    private async Task LoadInvitationsAsync()
    {
        _loading = true;
        try
        {
            var result = await InvitationService.GetInvitationsAsync(_organizationId, _statusFilter);
            _invitations = result.Invitations.ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load invitations: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SendInvitationAsync()
    {
        try
        {
            await InvitationService.CreateInvitationAsync(_organizationId, new CreateInvitationRequest
            {
                Email = _newEmail,
                Role = _newRole,
                ExpiryDays = _newExpiryDays
            });
            Snackbar.Add($"Invitation sent to {_newEmail}", Severity.Success);
            _newEmail = "";
            await LoadInvitationsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to send invitation: {ex.Message}", Severity.Error);
        }
    }

    private async Task RevokeAsync(Guid invitationId)
    {
        await InvitationService.RevokeInvitationAsync(_organizationId, invitationId);
        Snackbar.Add("Invitation revoked", Severity.Warning);
        await LoadInvitationsAsync();
    }

    private async Task ResendAsync(Guid invitationId)
    {
        await InvitationService.ResendInvitationAsync(_organizationId, invitationId);
        Snackbar.Add("Invitation resent", Severity.Success);
        await LoadInvitationsAsync();
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Pending" => Color.Info,
        "Accepted" => Color.Success,
        "Expired" => Color.Warning,
        "Revoked" => Color.Error,
        _ => Color.Default
    };
}
