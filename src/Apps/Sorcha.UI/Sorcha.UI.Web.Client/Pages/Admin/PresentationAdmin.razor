@page "/admin/presentations"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@attribute [Authorize(Roles = "Administrator")]
@implements IDisposable
@using Microsoft.AspNetCore.Authorization
@using Sorcha.UI.Core.Models.Credentials
@using Sorcha.UI.Core.Services.Credentials
@inject IPresentationAdminService PresentationAdminService

<PageTitle>Presentations - Sorcha Platform</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-2 px-0" />
    <MudText Typo="Typo.h4" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Filled.PresentToAll" Class="mr-2" />
        Presentation Requests
    </MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
        Create and manage verifiable presentation requests
    </MudText>

    @* Form Section *@
    <MudPaper Class="pa-4 mb-4" Elevation="1">
        <MudText Typo="Typo.h6" Class="mb-3">Create Presentation Request</MudText>

        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_credentialType"
                              Label="Credential Type"
                              Placeholder="e.g. VerifiableCredential"
                              Required="true"
                              Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_verifierIdentity"
                              Label="Verifier Identity"
                              Placeholder="e.g. did:example:verifier"
                              Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.body2" Class="mb-1">Accepted Issuers</MudText>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-1">
                    <MudTextField @bind-Value="_newIssuerInput"
                                  Placeholder="Enter issuer DID and press Enter"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  OnKeyUp="OnIssuerKeyUp"
                                  Immediate="true" />
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   OnClick="AddIssuer"
                                   Disabled="@string.IsNullOrWhiteSpace(_newIssuerInput)"
                                   Title="Add issuer" />
                </MudStack>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    @foreach (var issuer in _acceptedIssuersList)
                    {
                        var capturedIssuer = issuer;
                        <MudChip T="string"
                                 Color="Color.Primary"
                                 Variant="Variant.Outlined"
                                 Size="Size.Small"
                                 OnClose="@(_ => RemoveIssuer(capturedIssuer))">
                            @issuer
                        </MudChip>
                    }
                </MudStack>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.body2" Class="mb-1">Required Claims</MudText>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-1">
                    <MudTextField @bind-Value="_newClaimInput"
                                  Placeholder="Enter claim name and press Enter"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  OnKeyUp="OnClaimKeyUp"
                                  Immediate="true" />
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   OnClick="AddClaim"
                                   Disabled="@string.IsNullOrWhiteSpace(_newClaimInput)"
                                   Title="Add claim" />
                </MudStack>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    @foreach (var claim in _requiredClaimsList)
                    {
                        var capturedClaim = claim;
                        <MudChip T="string"
                                 Color="Color.Secondary"
                                 Variant="Variant.Outlined"
                                 Size="Size.Small"
                                 OnClose="@(_ => RemoveClaim(capturedClaim))">
                            @claim
                        </MudChip>
                    }
                </MudStack>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_targetWalletAddress"
                              Label="Target Wallet Address"
                              Placeholder="Optional wallet address"
                              Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_callbackUrl"
                              Label="Callback URL"
                              Placeholder="https://example.com/callback"
                              Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="_ttlSeconds"
                                 Label="TTL (seconds)"
                                 Min="30"
                                 Max="86400"
                                 Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Disabled="@(_creating || string.IsNullOrWhiteSpace(_credentialType))"
                           OnClick="CreateRequestAsync"
                           StartIcon="@Icons.Material.Filled.Add">
                    @if (_creating)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Create Request
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @* Error Display *@
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="() => _errorMessage = null">
            @_errorMessage
        </MudAlert>
    }

    @* Result Section *@
    @if (_result is not null)
    {
        <MudCard Class="mb-4" Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.h6">Presentation Request Created</MudText>
                        @if (_result.Status == "Pending")
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Info" />
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Auto-refreshing...</MudText>
                        }
                    </MudStack>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                @if (_result.IsExpired)
                {
                    <MudAlert Severity="Severity.Warning" Class="mb-3">
                        This presentation request has expired.
                    </MudAlert>
                }

                <MudSimpleTable Hover="true" Dense="true" Class="mb-4">
                    <thead>
                        <tr>
                            <th style="width: 200px;">Property</th>
                            <th>Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>Request ID</strong></td>
                            <td><MudText Typo="Typo.body2" Style="font-family: monospace;">@_result.RequestId</MudText></td>
                        </tr>
                        <tr>
                            <td><strong>Status</strong></td>
                            <td>
                                <MudChip T="string"
                                         Color="@GetStatusColor(_result.Status)"
                                         Size="Size.Small">
                                    @_result.Status
                                </MudChip>
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Expires At</strong></td>
                            <td>@_result.ExpiresAt.ToString("yyyy-MM-dd HH:mm:ss zzz")</td>
                        </tr>
                        <tr>
                            <td><strong>Time Remaining</strong></td>
                            <td>
                                @if (_result.IsExpired)
                                {
                                    <MudText Color="Color.Error">Expired</MudText>
                                }
                                else
                                {
                                    @_result.TimeRemaining.ToString(@"hh\:mm\:ss")
                                }
                            </td>
                        </tr>
                    </tbody>
                </MudSimpleTable>

                <MudTextField Value="@_result.RequestUrl"
                              Label="Request URL"
                              ReadOnly="true"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                              Class="mb-3" />

                @if (!string.IsNullOrEmpty(_result.QrCodeUrl))
                {
                    <MudText Typo="Typo.subtitle2" Class="mb-1">QR Code URL</MudText>
                    <MudText Typo="Typo.body2" Style="font-family: monospace; word-break: break-all;">
                        @_result.QrCodeUrl
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                        QR code rendering will be available in a future update.
                    </MudText>
                }
            </MudCardContent>
        </MudCard>
    }
</MudContainer>

@code {
    private string _credentialType = string.Empty;
    private string _newIssuerInput = string.Empty;
    private string _newClaimInput = string.Empty;
    private readonly List<string> _acceptedIssuersList = [];
    private readonly List<string> _requiredClaimsList = [];
    private string? _targetWalletAddress;
    private string _callbackUrl = string.Empty;
    private string? _verifierIdentity;
    private int _ttlSeconds = 300;
    private bool _creating;
    private string? _errorMessage;
    private PresentationRequestResultViewModel? _result;
    private System.Timers.Timer? _refreshTimer;
    private bool _disposed;

    private readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Admin", href: "/admin/health"),
        new("Presentations", href: null, disabled: true)
    ];

    // --- Chip input handlers for Accepted Issuers ---

    private void OnIssuerKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            AddIssuer();
    }

    private void AddIssuer()
    {
        var value = _newIssuerInput?.Trim();
        if (!string.IsNullOrEmpty(value) && !_acceptedIssuersList.Contains(value))
        {
            _acceptedIssuersList.Add(value);
            _newIssuerInput = string.Empty;
        }
    }

    private void RemoveIssuer(string issuer) => _acceptedIssuersList.Remove(issuer);

    // --- Chip input handlers for Required Claims ---

    private void OnClaimKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            AddClaim();
    }

    private void AddClaim()
    {
        var value = _newClaimInput?.Trim();
        if (!string.IsNullOrEmpty(value) && !_requiredClaimsList.Contains(value))
        {
            _requiredClaimsList.Add(value);
            _newClaimInput = string.Empty;
        }
    }

    private void RemoveClaim(string claim) => _requiredClaimsList.Remove(claim);

    // --- Auto-refresh for pending requests ---

    private void StartAutoRefresh()
    {
        StopAutoRefresh();
        if (_result is { Status: "Pending" })
        {
            _refreshTimer = new System.Timers.Timer(5000);
            _refreshTimer.Elapsed += async (_, _) => await InvokeAsync(PollResultAsync);
            _refreshTimer.AutoReset = true;
            _refreshTimer.Start();
        }
    }

    private void StopAutoRefresh()
    {
        _refreshTimer?.Stop();
        _refreshTimer?.Dispose();
        _refreshTimer = null;
    }

    private async Task PollResultAsync()
    {
        if (_disposed || _result is null) return;

        try
        {
            var updated = await PresentationAdminService.GetPresentationResultAsync(_result.RequestId);
            if (updated is not null)
            {
                _result = updated;
                if (updated.Status != "Pending")
                {
                    StopAutoRefresh();
                }
                await InvokeAsync(StateHasChanged);
            }
        }
        catch
        {
            // Resilience: polling failure is non-critical — next tick will retry
        }
    }

    // --- Create request ---

    private async Task CreateRequestAsync()
    {
        if (string.IsNullOrWhiteSpace(_credentialType))
            return;

        _creating = true;
        _errorMessage = null;
        _result = null;
        StopAutoRefresh();

        try
        {
            var request = new CreatePresentationRequestViewModel
            {
                CredentialType = _credentialType.Trim(),
                AcceptedIssuers = _acceptedIssuersList.ToArray(),
                RequiredClaims = _requiredClaimsList.ToArray(),
                CallbackUrl = _callbackUrl.Trim(),
                TargetWalletAddress = string.IsNullOrWhiteSpace(_targetWalletAddress) ? null : _targetWalletAddress.Trim(),
                TtlSeconds = _ttlSeconds,
                VerifierIdentity = string.IsNullOrWhiteSpace(_verifierIdentity) ? null : _verifierIdentity.Trim()
            };

            _result = await PresentationAdminService.CreatePresentationRequestAsync(request);

            if (_result is null)
            {
                _errorMessage = "Failed to create presentation request. The service returned no result.";
            }
            else
            {
                StartAutoRefresh();
            }
        }
        catch (HttpRequestException ex)
        {
            _errorMessage = $"Error creating presentation request: {ex.Message}";
        }
        finally
        {
            _creating = false;
        }
    }

    private static Color GetStatusColor(string status) => status switch
    {
        "Pending" => Color.Info,
        "Completed" or "Verified" => Color.Success,
        "Expired" => Color.Warning,
        "Rejected" or "Failed" => Color.Error,
        _ => Color.Default
    };

    public void Dispose()
    {
        _disposed = true;
        StopAutoRefresh();
    }
}
