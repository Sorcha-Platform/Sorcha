@page "/auth/login"
@layout AuthLayout
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using System.Net.Http.Json
@using System.Text.Json
@using Sorcha.UI.Core.Models.Authentication
@using Sorcha.UI.Core.Models.Configuration
@using Sorcha.UI.Core.Services.Authentication
@using Sorcha.UI.Core.Services.Configuration
@using Sorcha.UI.Core.Services.Navigation
@using Sorcha.UI.Web.Client.Components.Layout
@using Sorcha.UI.Web.Client.Services
@inject IAuthenticationService AuthService
@inject IConfigurationService ConfigService
@inject INavigationService NavigationService
@inject CustomAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject HttpClient Http
@inject PasskeyInteropService PasskeyInterop

<PageTitle>Sign In - Sorcha</PageTitle>

<ErrorBoundary>
    <ChildContent>
        @if (!_profilesLoaded)
        {
            <div class="text-center" style="margin: 100px auto;">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-3">Loading profiles...</p>
            </div>
        }
        else
        {
            @if (_profileLoadError && !string.IsNullOrEmpty(_profileErrorMessage))
            {
                <div class="alert alert-info alert-dismissible fade show" style="max-width: 500px; margin: 20px auto;" role="alert">
                    <strong>Note:</strong> @_profileErrorMessage. Using default profiles.
                    <button type="button" class="btn-close" @onclick="@(() => _profileLoadError = false)"></button>
                </div>
            }

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger" style="max-width: 500px; margin: 10px auto;">@_errorMessage</div>
            }

            <div class="login-card">
                <div class="login-header">
                    <h2 class="login-title">Sign In</h2>
                    <p class="login-subtitle">Access your Sorcha account</p>
                </div>

                <div class="login-body">
                    @if (!_requiresTwoFactor)
                    {
                        @* Standard login form *@
                        <div class="mb-3">
                            <label class="form-label">Environment</label>
                            <select class="form-select" @bind="_selectedProfile">
                                @foreach (var profile in _profiles)
                                {
                                    <option value="@profile.Name">@profile.Name</option>
                                }
                            </select>
                            @if (!string.IsNullOrEmpty(_selectedProfile))
                            {
                                var selectedProfileInfo = _profiles.FirstOrDefault(p => p.Name == _selectedProfile);
                                @if (selectedProfileInfo != null)
                                {
                                    <small class="form-text text-muted">@selectedProfileInfo.Description</small>
                                }
                            }
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Username</label>
                            <input type="text"
                                   class="form-control"
                                   @bind="_username"
                                   @onkeydown="HandleKeyDown"
                                   placeholder="Enter your username"
                                   autocomplete="username" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Password</label>
                            <input type="password"
                                   class="form-control"
                                   @bind="_password"
                                   @onkeydown="HandleKeyDown"
                                   placeholder="Enter your password"
                                   autocomplete="current-password" />
                        </div>

                        <button class="btn btn-primary w-100 btn-lg" @onclick="HandleLogin" disabled="@_isLoading">
                            @if (_isLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>Signing in...</span>
                            }
                            else
                            {
                                <span>Sign In</span>
                            }
                        </button>

                        @* Passkey sign-in (discoverable flow) *@
                        @if (_webAuthnSupported)
                        {
                            <div class="divider-row">
                                <hr class="divider-line" />
                                <span class="divider-text">or</span>
                                <hr class="divider-line" />
                            </div>

                            <button class="btn btn-outline-secondary w-100 btn-lg passkey-btn"
                                    @onclick="HandlePasskeySignIn"
                                    disabled="@_isPasskeyProcessing">
                                @if (_isPasskeyProcessing)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                    <span>Authenticating...</span>
                                }
                                else
                                {
                                    <span class="passkey-icon me-2">&#128273;</span>
                                    <span>Sign in with Passkey</span>
                                }
                            </button>
                        }

                        <div class="text-center mt-3">
                            <a href="/auth/public/signup" class="text-decoration-none">
                                Don't have an account? Sign up
                            </a>
                        </div>
                    }
                    else
                    {
                        @* Two-factor authentication UI *@
                        <div class="two-factor-section">
                            <h5 class="mb-3">Two-Factor Authentication</h5>
                            <p class="text-muted mb-4">@(_twoFactorMessage ?? "Additional verification is required to complete sign-in.")</p>

                            @if (_availableMethods.Length > 1)
                            {
                                <div class="method-selector mb-4">
                                    <label class="form-label">Verification method</label>
                                    <div class="btn-group w-100" role="group">
                                        @foreach (var method in _availableMethods)
                                        {
                                            var isActive = _selectedMethod == method;
                                            <button type="button"
                                                    class="btn @(isActive ? "btn-primary" : "btn-outline-primary")"
                                                    @onclick="@(() => _selectedMethod = method)">
                                                @GetMethodDisplayName(method)
                                            </button>
                                        }
                                    </div>
                                </div>
                            }

                            @if (_selectedMethod == "totp")
                            {
                                <div class="mb-3">
                                    <label class="form-label">Verification code</label>
                                    <input type="text"
                                           class="form-control form-control-lg text-center"
                                           @bind="_totpCode"
                                           @onkeydown="HandleTotpKeyDown"
                                           placeholder="000000"
                                           maxlength="8"
                                           autocomplete="one-time-code"
                                           inputmode="numeric"
                                           style="letter-spacing: 0.5em; font-size: 1.5rem;" />
                                    <small class="form-text text-muted">
                                        Enter the 6-digit code from your authenticator app, or an 8-character backup code.
                                    </small>
                                </div>

                                <button class="btn btn-primary w-100 btn-lg"
                                        @onclick="HandleTotpVerify"
                                        disabled="@(_isLoading || string.IsNullOrWhiteSpace(_totpCode))">
                                    @if (_isLoading)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                        <span>Verifying...</span>
                                    }
                                    else
                                    {
                                        <span>Verify</span>
                                    }
                                </button>
                            }
                            else if (_selectedMethod == "passkey")
                            {
                                <div class="text-center mb-3">
                                    <p>Use your registered passkey to complete sign-in.</p>
                                </div>

                                <button class="btn btn-primary w-100 btn-lg passkey-btn"
                                        @onclick="HandlePasskey2Fa"
                                        disabled="@_isPasskeyProcessing">
                                    @if (_isPasskeyProcessing)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                        <span>Waiting for passkey...</span>
                                    }
                                    else
                                    {
                                        <span class="passkey-icon me-2">&#128273;</span>
                                        <span>Use Passkey</span>
                                    }
                                </button>
                            }

                            <div class="text-center mt-3">
                                <button class="btn btn-link text-decoration-none" @onclick="CancelTwoFactor">
                                    Cancel and return to sign-in
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <style>
                .login-card {
                    background: white;
                    border-radius: 12px;
                    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
                    overflow: hidden;
                }

                .login-header {
                    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                    color: white;
                    padding: 2rem;
                    text-align: center;
                }

                .login-title {
                    font-size: 2rem;
                    font-weight: 600;
                    margin: 0 0 0.5rem 0;
                }

                .login-subtitle {
                    margin: 0;
                    opacity: 0.9;
                    font-size: 1rem;
                }

                .login-body {
                    padding: 2rem;
                }

                .login-card .form-label {
                    font-weight: 500;
                    margin-bottom: 0.5rem;
                }

                .login-card .form-control,
                .login-card .form-select {
                    padding: 0.75rem 1rem;
                    font-size: 1rem;
                }

                .login-card .btn-primary {
                    padding: 0.75rem;
                    font-size: 1.1rem;
                    font-weight: 500;
                }

                .divider-row {
                    display: flex;
                    align-items: center;
                    margin: 1.5rem 0;
                }

                .divider-line {
                    flex: 1;
                    border: none;
                    border-top: 1px solid #dee2e6;
                    margin: 0;
                }

                .divider-text {
                    padding: 0 1rem;
                    color: #6c757d;
                    font-size: 0.9rem;
                }

                .passkey-btn {
                    display: flex;
                    align-items: center;
                    justify-content: center;
                }

                .passkey-icon {
                    font-size: 1.2rem;
                }

                .two-factor-section h5 {
                    font-weight: 600;
                    color: #333;
                }

                .method-selector .btn-group .btn {
                    flex: 1;
                }
            </style>
        }
    </ChildContent>
    <ErrorContent Context="exception">
        <div class="alert alert-warning" style="max-width: 500px; margin: 50px auto;">
            <h5 class="alert-heading">Profile Loading Issue</h5>
            <p>Unable to load saved profiles. You can continue with the default development profile.</p>
            <hr>
            <button class="btn btn-primary" @onclick="UseDefaultProfilesAndContinue">
                Continue with Default Profile
            </button>
            <details class="mt-3">
                <summary>Error Details</summary>
                <pre class="mt-2 small">@exception.Message</pre>
            </details>
        </div>
    </ErrorContent>
</ErrorBoundary>

@code {
    /// <summary>
    /// Optional return URL to navigate to after successful login.
    /// </summary>
    [Parameter]
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private List<Profile> _profiles = new();
    private string _selectedProfile = "Development";
    private string _username = "";
    private string _password = "";
    private string _errorMessage = "";
    private bool _isLoading = false;
    private bool _profilesLoaded = true; // Start as loaded with hardcoded profiles
    private bool _profileLoadError = false;
    private string? _profileErrorMessage = null;

    // WebAuthn support
    private bool _webAuthnSupported;
    private bool _isPasskeyProcessing;

    // Two-factor authentication state
    private bool _requiresTwoFactor;
    private string _loginToken = "";
    private string[] _availableMethods = [];
    private string _selectedMethod = "";
    private string? _twoFactorMessage;
    private string _totpCode = "";

    protected override void OnInitialized()
    {
        // Use ProfileDefaults to avoid async initialization issues
        _profiles = ProfileDefaults.GetDefaultProfiles();
        _selectedProfile = ProfileDefaults.DefaultActiveProfile;
        _profilesLoaded = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _webAuthnSupported = await PasskeyInterop.IsWebAuthnSupportedAsync();
                StateHasChanged();
            }
            catch (JSException)
            {
                // WebAuthn not available — passkey button stays hidden
                _webAuthnSupported = false;
            }
        }
    }

    private void UseDefaultProfilesAndContinue()
    {
        // Use ProfileDefaults for consistent profile definitions
        _profiles = ProfileDefaults.GetDefaultProfiles();
        _selectedProfile = ProfileDefaults.DefaultActiveProfile;
        _profilesLoaded = true;
        _errorMessage = "";

        // Force component to re-render and show the login form
        StateHasChanged();
    }

    /// <summary>
    /// Handles keyboard events on input fields.
    /// Submits the form when Enter is pressed.
    /// </summary>
    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_isLoading)
        {
            await HandleLogin();
        }
    }

    /// <summary>
    /// Handles keyboard events on the TOTP input field.
    /// </summary>
    private async Task HandleTotpKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_isLoading && !string.IsNullOrWhiteSpace(_totpCode))
        {
            await HandleTotpVerify();
        }
    }

    private async Task HandleLogin()
    {
        _errorMessage = "";
        _isLoading = true;

        try
        {
            var request = new LoginRequest
            {
                Username = _username,
                Password = _password
            };

            if (!request.IsValid())
            {
                _errorMessage = "Please enter valid username and password";
                return;
            }

            // Set active profile
            await ConfigService.SetActiveProfileAsync(_selectedProfile);

            // Perform login with 2FA detection
            var result = await AuthService.LoginWithTwoFactorAsync(request, _selectedProfile);

            if (result.RequiresTwoFactor)
            {
                // Enter 2FA mode
                _requiresTwoFactor = true;
                _loginToken = result.LoginToken!;
                _availableMethods = result.AvailableMethods;
                _twoFactorMessage = result.Message;

                // Default to passkey if available, otherwise totp
                _selectedMethod = _availableMethods.Contains("passkey") ? "passkey" : _availableMethods.FirstOrDefault() ?? "totp";
                return;
            }

            // Login succeeded without 2FA
            await CompleteLogin();
        }
        catch (HttpRequestException ex)
        {
            _errorMessage = $"Login failed: {ex.Message}";
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    /// <summary>
    /// Handles TOTP code verification for 2FA.
    /// </summary>
    private async Task HandleTotpVerify()
    {
        _errorMessage = "";
        _isLoading = true;

        try
        {
            var payload = new
            {
                login_token = _loginToken,
                code = _totpCode.Trim(),
                is_backup_code = _totpCode.Trim().Length > 6
            };

            var response = await Http.PostAsJsonAsync("/api/auth/verify-2fa", payload);

            if (!response.IsSuccessStatusCode)
            {
                var errorBody = await response.Content.ReadAsStringAsync();
                _errorMessage = response.StatusCode == System.Net.HttpStatusCode.Unauthorized
                    ? "Invalid verification code. Please try again."
                    : $"Verification failed: {response.StatusCode}";
                return;
            }

            var tokenResponse = await response.Content.ReadFromJsonAsync<TokenResponse>();
            if (tokenResponse == null || !tokenResponse.IsValid())
            {
                _errorMessage = "Invalid token response from server.";
                return;
            }

            await AuthService.StoreExternalTokenAsync(tokenResponse, _selectedProfile);
            await CompleteLogin();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Verification error: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    /// <summary>
    /// Handles passkey 2FA verification ceremony.
    /// </summary>
    private async Task HandlePasskey2Fa()
    {
        _errorMessage = "";
        _isPasskeyProcessing = true;

        try
        {
            // Step 1: Get assertion options from server
            var optionsPayload = new { login_token = _loginToken };
            var optionsResponse = await Http.PostAsJsonAsync("/api/auth/verify-passkey/options", optionsPayload);

            if (!optionsResponse.IsSuccessStatusCode)
            {
                _errorMessage = "Failed to get passkey options. Please try again.";
                return;
            }

            var optionsJson = await optionsResponse.Content.ReadAsStringAsync();
            using var optionsDoc = JsonDocument.Parse(optionsJson);
            var transactionId = optionsDoc.RootElement.GetProperty("transaction_id").GetString()!;
            var assertionOptions = optionsDoc.RootElement.GetProperty("options");

            // Step 2: Trigger browser WebAuthn ceremony
            var assertionResponse = await PasskeyInterop.GetCredentialAsync(assertionOptions);

            // Step 3: Send assertion response to server for verification
            var verifyPayload = new
            {
                login_token = _loginToken,
                transaction_id = transactionId,
                assertion_response = assertionResponse
            };

            var verifyResponse = await Http.PostAsJsonAsync("/api/auth/verify-passkey", verifyPayload);

            if (!verifyResponse.IsSuccessStatusCode)
            {
                _errorMessage = "Passkey verification failed. Please try again.";
                return;
            }

            var tokenResponse = await verifyResponse.Content.ReadFromJsonAsync<TokenResponse>();
            if (tokenResponse == null || !tokenResponse.IsValid())
            {
                _errorMessage = "Invalid token response from server.";
                return;
            }

            await AuthService.StoreExternalTokenAsync(tokenResponse, _selectedProfile);
            await CompleteLogin();
        }
        catch (JSException ex)
        {
            // User cancelled the WebAuthn ceremony or it timed out
            if (ex.Message.Contains("NotAllowedError") || ex.Message.Contains("AbortError"))
            {
                _errorMessage = "Passkey operation was cancelled.";
            }
            else
            {
                _errorMessage = $"Passkey error: {ex.Message}";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            _isPasskeyProcessing = false;
        }
    }

    /// <summary>
    /// Handles standalone passkey sign-in (discoverable credential flow).
    /// </summary>
    private async Task HandlePasskeySignIn()
    {
        _errorMessage = "";
        _isPasskeyProcessing = true;

        try
        {
            // Set active profile before making API calls
            await ConfigService.SetActiveProfileAsync(_selectedProfile);

            // Step 1: Get assertion options (no email = discoverable flow)
            var optionsPayload = new { email = (string?)null };
            var optionsResponse = await Http.PostAsJsonAsync("/api/auth/passkey/assertion/options", optionsPayload);

            if (!optionsResponse.IsSuccessStatusCode)
            {
                _errorMessage = "Failed to initiate passkey sign-in. Please try again.";
                return;
            }

            var optionsJson = await optionsResponse.Content.ReadAsStringAsync();
            using var optionsDoc = JsonDocument.Parse(optionsJson);
            var transactionId = optionsDoc.RootElement.GetProperty("transaction_id").GetString()!;
            var assertionOptions = optionsDoc.RootElement.GetProperty("options");

            // Step 2: Trigger browser WebAuthn ceremony
            var assertionResponse = await PasskeyInterop.GetCredentialAsync(assertionOptions);

            // Step 3: Send assertion response to server for verification
            var verifyPayload = new
            {
                transaction_id = transactionId,
                assertion_response = assertionResponse
            };

            var verifyResponse = await Http.PostAsJsonAsync("/api/auth/passkey/assertion/verify", verifyPayload);

            if (!verifyResponse.IsSuccessStatusCode)
            {
                _errorMessage = "Passkey sign-in failed. Please try again or use username/password.";
                return;
            }

            var tokenResponse = await verifyResponse.Content.ReadFromJsonAsync<TokenResponse>();
            if (tokenResponse == null || !tokenResponse.IsValid())
            {
                _errorMessage = "Invalid token response from server.";
                return;
            }

            await AuthService.StoreExternalTokenAsync(tokenResponse, _selectedProfile);
            await CompleteLogin();
        }
        catch (JSException ex)
        {
            if (ex.Message.Contains("NotAllowedError") || ex.Message.Contains("AbortError"))
            {
                _errorMessage = "Passkey operation was cancelled.";
            }
            else
            {
                _errorMessage = $"Passkey error: {ex.Message}";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            _isPasskeyProcessing = false;
        }
    }

    /// <summary>
    /// Completes the login flow after successful authentication (with or without 2FA).
    /// </summary>
    private async Task CompleteLogin()
    {
        // Give the token cache a moment to persist (Blazor WASM LocalStorage timing)
        await Task.Delay(100);

        // Notify authentication state changed
        AuthStateProvider.NotifyAuthenticationStateChanged();

        // Small delay to ensure state propagates before navigation
        await Task.Delay(100);

        // Navigate to return URL if provided and valid, otherwise go to dashboard
        NavigationService.NavigateToValidatedUrl(ReturnUrl, "dashboard");
    }

    /// <summary>
    /// Cancels the 2FA flow and returns to the standard login form.
    /// </summary>
    private void CancelTwoFactor()
    {
        _requiresTwoFactor = false;
        _loginToken = "";
        _availableMethods = [];
        _selectedMethod = "";
        _totpCode = "";
        _twoFactorMessage = null;
        _errorMessage = "";
        _password = "";
    }

    /// <summary>
    /// Gets a human-readable display name for a 2FA method.
    /// </summary>
    private static string GetMethodDisplayName(string method) => method switch
    {
        "totp" => "Authenticator Code",
        "passkey" => "Passkey",
        _ => method
    };
}
