    <PackageReference Include="JsonLogic" />
    <PackageReference Include="JsonSchema.Net" />
    <PackageReference Include="Microsoft.Extensions.Http" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Sorcha.UI.Core\Sorcha.UI.Core.csproj" />
