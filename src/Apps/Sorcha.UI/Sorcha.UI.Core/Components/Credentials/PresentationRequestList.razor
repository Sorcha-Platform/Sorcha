@using MudBlazor
@using Sorcha.UI.Core.Models.Credentials
@using Sorcha.UI.Core.Services.Credentials

@inject ICredentialApiService CredentialApiService

<MudStack Spacing="3">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h6">Presentation Requests</MudText>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="LoadRequestsAsync" Disabled="_loading">
            Refresh
        </MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (_requests.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            No pending presentation requests.
        </MudAlert>
    }
    else
    {
        <MudTable Items="_requests" Hover="true" Dense="true" Striped="true"
                  RowClassFunc="GetRowClass"
                  OnRowClick="OnRowClicked" T="PresentationRequestViewModel">
            <HeaderContent>
                <MudTh>Verifier Identity</MudTh>
                <MudTh>Credential Type</MudTh>
                <MudTh>Expires At</MudTh>
                <MudTh>Status</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Verifier Identity">
                    <MudText Typo="Typo.body2">@context.VerifierIdentity</MudText>
                </MudTd>
                <MudTd DataLabel="Credential Type">
                    <MudText Typo="Typo.body2">@context.CredentialType</MudText>
                </MudTd>
                <MudTd DataLabel="Expires At">
                    <MudText Typo="Typo.body2" Color="@(context.IsExpired ? Color.Error : Color.Default)">
                        @context.ExpiresAt.ToString("yyyy-MM-dd HH:mm:ss")
                    </MudText>
                </MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Color="@GetStatusColor(context)" Variant="Variant.Filled" Size="MudBlazor.Size.Small">
                        @(context.IsExpired ? "Expired" : context.Status)
                    </MudChip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudStack>

@code {
    [Parameter, EditorRequired]
    public string WalletAddress { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<PresentationRequestViewModel> OnRequestSelected { get; set; }

    private List<PresentationRequestViewModel> _requests = new();
    private bool _loading;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadRequestsAsync();
            StateHasChanged();
        }
    }

    private async Task LoadRequestsAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            _requests = await CredentialApiService.GetPresentationRequestsAsync(WalletAddress);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnRowClicked(TableRowClickEventArgs<PresentationRequestViewModel> args)
    {
        if (args.Item is not null)
        {
            await OnRequestSelected.InvokeAsync(args.Item);
        }
    }

    private string GetRowClass(PresentationRequestViewModel item, int index)
    {
        return item.IsExpired ? "mud-text-disabled" : string.Empty;
    }

    private Color GetStatusColor(PresentationRequestViewModel request)
    {
        if (request.IsExpired) return Color.Default;
        return request.Status switch
        {
            "Pending" => Color.Warning,
            "Approved" => Color.Success,
            "Denied" => Color.Error,
            _ => Color.Default
        };
    }
}
