@using MudBlazor
@using Sorcha.UI.Core.Models.Credentials

<MudStack Spacing="3">
    @* Header *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudIcon Icon="@Icons.Material.Filled.FactCheck" Color="Color.Primary" />
        <MudText Typo="Typo.h6">Presentation Request</MudText>
    </MudStack>

    @* Expiry warning *@
    @if (Request.IsExpired)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
            This request has expired.
        </MudAlert>
    }

    @* Request details *@
    <MudSimpleTable Dense="true" Hover="true" Bordered="false">
        <tbody>
            <tr>
                <td><MudText Typo="Typo.body2" Color="Color.Secondary">Request ID</MudText></td>
                <td><MudText Typo="Typo.body2">@Request.RequestId</MudText></td>
            </tr>
            <tr>
                <td><MudText Typo="Typo.body2" Color="Color.Secondary">Verifier</MudText></td>
                <td><MudText Typo="Typo.body2">@Request.VerifierIdentity</MudText></td>
            </tr>
            <tr>
                <td><MudText Typo="Typo.body2" Color="Color.Secondary">Credential Type</MudText></td>
                <td><MudText Typo="Typo.body2">@Request.CredentialType</MudText></td>
            </tr>
            <tr>
                <td><MudText Typo="Typo.body2" Color="Color.Secondary">Status</MudText></td>
                <td>
                    <MudChip T="string" Color="@(Request.IsExpired ? Color.Default : Color.Warning)"
                             Variant="Variant.Filled" Size="MudBlazor.Size.Small">
                        @(Request.IsExpired ? "Expired" : Request.Status)
                    </MudChip>
                </td>
            </tr>
            <tr>
                <td><MudText Typo="Typo.body2" Color="Color.Secondary">Expires</MudText></td>
                <td>
                    @if (Request.IsExpired)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Error">
                            Expired @Request.ExpiresAt.ToString("yyyy-MM-dd HH:mm:ss")
                        </MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">
                            @FormatTimeRemaining() remaining (@Request.ExpiresAt.ToString("yyyy-MM-dd HH:mm:ss"))
                        </MudText>
                    }
                </td>
            </tr>
        </tbody>
    </MudSimpleTable>

    @* Required claims *@
    <MudText Typo="Typo.subtitle2" Class="mt-2">Required Claims</MudText>
    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
        @foreach (var claim in Request.RequestedClaims)
        {
            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="MudBlazor.Size.Small">
                @claim
            </MudChip>
        }
    </MudStack>

    @* Matching credentials *@
    @if (Request.MatchingCredentials.Count > 0)
    {
        <MudText Typo="Typo.subtitle2" Class="mt-2">Matching Credentials</MudText>
        <MudList T="MatchingCredentialViewModel" Dense="true">
            @foreach (var credential in Request.MatchingCredentials)
            {
                <MudListItem T="MatchingCredentialViewModel" Icon="@Icons.Material.Filled.Badge">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.body2">@credential.Type</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Issuer: @credential.IssuerDid
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Claims: @string.Join(", ", credential.AvailableClaims)
                        </MudText>
                        @if (credential.ExpiresAt.HasValue)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Expires: @credential.ExpiresAt.Value.ToString("yyyy-MM-dd")
                            </MudText>
                        }
                    </MudStack>
                </MudListItem>
            }
        </MudList>
    }
    else
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
            No matching credentials found in your wallet.
        </MudAlert>
    }

    @* Action buttons *@
    <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd" Class="mt-2">
        <MudButton Variant="Variant.Filled" Color="Color.Success"
                   StartIcon="@Icons.Material.Filled.Check"
                   OnClick="@(() => OnApproved.InvokeAsync())"
                   Disabled="@Request.IsExpired">
            Approve
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.Close"
                   OnClick="@(() => OnDenied.InvokeAsync())"
                   Disabled="@Request.IsExpired">
            Deny
        </MudButton>
    </MudStack>
</MudStack>

@code {
    [Parameter, EditorRequired]
    public PresentationRequestViewModel Request { get; set; } = default!;

    [Parameter]
    public EventCallback OnApproved { get; set; }

    [Parameter]
    public EventCallback OnDenied { get; set; }

    private string FormatTimeRemaining()
    {
        var remaining = Request.TimeRemaining;
        if (remaining.TotalHours >= 1)
            return $"{(int)remaining.TotalHours}h {remaining.Minutes}m";
        if (remaining.TotalMinutes >= 1)
            return $"{(int)remaining.TotalMinutes}m {remaining.Seconds}s";
        return $"{(int)remaining.TotalSeconds}s";
    }
}
