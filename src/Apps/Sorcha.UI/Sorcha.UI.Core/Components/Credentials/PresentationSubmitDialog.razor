@using MudBlazor
@using Sorcha.UI.Core.Models.Credentials

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Share" />
            <MudText Typo="Typo.h6">Submit Presentation</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            @* Request summary *@
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @Request.VerifierIdentity is requesting a <strong>@Request.CredentialType</strong> credential.
            </MudText>

            @* Credential selection *@
            <MudSelect T="string" Label="Select Credential" @bind-Value="_selectedCredentialId"
                       Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter"
                       Required="true" RequiredError="A credential must be selected">
                @foreach (var credential in Request.MatchingCredentials)
                {
                    <MudSelectItem T="string" Value="@credential.CredentialId">
                        @credential.Type — @credential.IssuerDid
                        @if (credential.ExpiresAt.HasValue)
                        {
                            @($" (expires {credential.ExpiresAt.Value:yyyy-MM-dd})")
                        }
                    </MudSelectItem>
                }
            </MudSelect>

            @* Claim checkboxes *@
            @if (_selectedCredential is not null)
            {
                <MudDivider />
                <MudText Typo="Typo.subtitle2">Select Claims to Disclose</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Required claims are pre-selected and cannot be deselected.
                </MudText>

                <MudStack Spacing="1">
                    @foreach (var claim in _selectedCredential.AvailableClaims)
                    {
                        var isRequired = Request.RequestedClaims.Contains(claim);
                        <MudCheckBox T="bool"
                                     Label="@claim"
                                     Value="@_selectedClaims.Contains(claim)"
                                     ValueChanged="@((bool val) => OnClaimToggled(claim, val))"
                                     Disabled="@isRequired"
                                     Color="@(isRequired ? Color.Primary : Color.Default)" />
                    }
                </MudStack>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Send"
                   OnClick="Confirm" Disabled="@(!CanSubmit)">
            Confirm
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter, EditorRequired]
    public PresentationRequestViewModel Request { get; set; } = default!;

    private string? _selectedCredentialId;
    private MatchingCredentialViewModel? _selectedCredential;
    private HashSet<string> _selectedClaims = new();

    private bool CanSubmit =>
        _selectedCredential is not null &&
        Request.RequestedClaims.All(rc => _selectedClaims.Contains(rc));

    protected override void OnParametersSet()
    {
        // Reset selection when request changes
        _selectedCredentialId = null;
        _selectedCredential = null;
        _selectedClaims.Clear();
    }

    // Watch for credential selection changes
    protected override void OnAfterRender(bool firstRender)
    {
        if (_selectedCredentialId is not null)
        {
            var newSelection = Request.MatchingCredentials
                .FirstOrDefault(c => c.CredentialId == _selectedCredentialId);

            if (newSelection != _selectedCredential)
            {
                _selectedCredential = newSelection;
                _selectedClaims.Clear();

                if (_selectedCredential is not null)
                {
                    // Pre-select required claims
                    foreach (var requiredClaim in Request.RequestedClaims)
                    {
                        if (_selectedCredential.AvailableClaims.Contains(requiredClaim))
                        {
                            _selectedClaims.Add(requiredClaim);
                        }
                    }
                }

                StateHasChanged();
            }
        }
        else if (_selectedCredential is not null)
        {
            _selectedCredential = null;
            _selectedClaims.Clear();
            StateHasChanged();
        }
    }

    private void OnClaimToggled(string claim, bool isChecked)
    {
        // Required claims cannot be toggled off
        if (Request.RequestedClaims.Contains(claim))
            return;

        if (isChecked)
            _selectedClaims.Add(claim);
        else
            _selectedClaims.Remove(claim);
    }

    private void Confirm()
    {
        if (!CanSubmit || _selectedCredentialId is null) return;

        var result = new PresentationSubmitDialogResult(
            _selectedCredentialId,
            _selectedClaims.ToList());

        MudDialog.Close(DialogResult.Ok(result));
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    /// <summary>
    /// Result returned from the dialog containing the selected credential and claims.
    /// </summary>
    public record PresentationSubmitDialogResult(
        string SelectedCredentialId,
        List<string> SelectedClaims);
}
