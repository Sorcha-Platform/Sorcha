@using MudBlazor
@using Sorcha.UI.Core.Models.Credentials

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@GetActionIcon()" />
            <MudText Typo="Typo.h6">@Action Credential</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Credential: @CredentialId
            </MudText>

            @if (Action == CredentialLifecycleAction.Revoke)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
                    This action is irreversible
                </MudAlert>
            }

            <MudSelect T="string" Label="Issuer Wallet" @bind-Value="_selectedWallet"
                       Variant="Variant.Outlined" Required="true"
                       AnchorOrigin="Origin.BottomCenter">
                @foreach (var wallet in AvailableWallets)
                {
                    <MudSelectItem T="string" Value="@wallet">@wallet</MudSelectItem>
                }
            </MudSelect>

            @if (Action == CredentialLifecycleAction.Refresh)
            {
                <MudTextField T="int?" Label="New Expiry Duration (days)" @bind-Value="_expiryDays"
                              Variant="Variant.Outlined"
                              InputType="InputType.Number" />
            }
            else
            {
                <MudTextField T="string" Label="Reason" @bind-Value="_reason"
                              Variant="Variant.Outlined"
                              Lines="3"
                              Placeholder="@GetReasonPlaceholder()" />
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="@GetConfirmColor()" Variant="Variant.Filled"
                   Disabled="@(string.IsNullOrWhiteSpace(_selectedWallet))"
                   OnClick="Confirm">
            @Action
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter, EditorRequired]
    public CredentialLifecycleAction Action { get; set; }

    [Parameter, EditorRequired]
    public string CredentialId { get; set; } = string.Empty;

    [Parameter]
    public List<string> AvailableWallets { get; set; } = new();

    private string? _selectedWallet;
    private string? _reason;
    private int? _expiryDays;

    private void Cancel() => MudDialog.Cancel();

    private void Confirm()
    {
        var request = new CredentialLifecycleRequest
        {
            CredentialId = CredentialId,
            IssuerWallet = _selectedWallet!,
            Action = Action,
            Reason = _reason,
            NewExpiryDuration = _expiryDays?.ToString()
        };

        MudDialog.Close(DialogResult.Ok(request));
    }

    private string GetActionIcon() => Action switch
    {
        CredentialLifecycleAction.Suspend => Icons.Material.Filled.Pause,
        CredentialLifecycleAction.Reinstate => Icons.Material.Filled.PlayArrow,
        CredentialLifecycleAction.Revoke => Icons.Material.Filled.Cancel,
        CredentialLifecycleAction.Refresh => Icons.Material.Filled.Refresh,
        _ => Icons.Material.Filled.Info
    };

    private Color GetConfirmColor() => Action switch
    {
        CredentialLifecycleAction.Suspend => Color.Warning,
        CredentialLifecycleAction.Reinstate => Color.Success,
        CredentialLifecycleAction.Revoke => Color.Error,
        CredentialLifecycleAction.Refresh => Color.Primary,
        _ => Color.Primary
    };

    private string GetReasonPlaceholder() => Action switch
    {
        CredentialLifecycleAction.Suspend => "Reason for suspension...",
        CredentialLifecycleAction.Reinstate => "Reason for reinstatement...",
        CredentialLifecycleAction.Revoke => "Reason for revocation...",
        _ => "Reason..."
    };
}
