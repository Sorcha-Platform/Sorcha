@inject IServicePrincipalService ServicePrincipalService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" />
            Edit Scopes — @PrincipalName
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width: 480px;">
            @if (_error is not null)
            {
                <MudAlert Severity="Severity.Error" Dense="true" CloseIconClicked="() => _error = null" ShowCloseIcon="true">
                    @_error
                </MudAlert>
            }

            <MudSelect T="string" Label="Scopes" MultiSelection="true" @bind-SelectedValues="_selectedScopes"
                       Variant="Variant.Outlined" SelectAll="true" SelectAllText="Select All">
                @foreach (var scope in AvailableScopes)
                {
                    <MudSelectItem T="string" Value="@scope">@scope</MudSelectItem>
                }
            </MudSelect>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Color="Color.Default">Cancel</MudButton>
        <MudButton OnClick="SaveAsync" Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="@_isSaving">
            @if (_isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public Guid PrincipalId { get; set; }

    [Parameter]
    public string PrincipalName { get; set; } = string.Empty;

    [Parameter]
    public string[] CurrentScopes { get; set; } = [];

    private static readonly string[] AvailableScopes =
    [
        "blueprints:read", "blueprints:write",
        "registers:read", "registers:write",
        "wallets:manage", "signing:execute",
        "transactions:validate", "consensus:participate",
        "peers:manage", "sync:replicate",
        "instances:manage"
    ];

    private IReadOnlyCollection<string> _selectedScopes = new HashSet<string>();
    private bool _isSaving;
    private string? _error;

    protected override void OnParametersSet()
    {
        _selectedScopes = CurrentScopes.ToHashSet();
    }

    private async Task SaveAsync()
    {
        _isSaving = true;
        _error = null;
        StateHasChanged();

        try
        {
            await ServicePrincipalService.UpdateScopesAsync(PrincipalId, _selectedScopes.ToArray());
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            _error = $"Failed to update scopes: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
