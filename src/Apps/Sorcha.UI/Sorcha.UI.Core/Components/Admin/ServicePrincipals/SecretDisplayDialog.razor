@inject IJSRuntime JsRuntime

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Key" Class="mr-2" />
            Service Principal Credentials
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width: 480px;">
            <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Dense="false">
                @Secret.Warning
            </MudAlert>

            <MudTextField T="string" Label="Client ID" Value="@Secret.ClientId" ReadOnly="true"
                          Variant="Variant.Outlined" Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                          OnAdornmentClick="@(() => CopyToClipboardAsync(Secret.ClientId))" />

            <MudTextField T="string" Label="Client Secret" Value="@Secret.ClientSecret" ReadOnly="true"
                          Variant="Variant.Outlined" Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                          OnAdornmentClick="@(() => CopyToClipboardAsync(Secret.ClientSecret))"
                          InputType="InputType.Password" />

            @if (_copied)
            {
                <MudAlert Severity="Severity.Success" Dense="true" Variant="Variant.Text">
                    Copied to clipboard
                </MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Color="Color.Primary" Variant="Variant.Filled">
            I have saved these credentials
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public ServicePrincipalSecretViewModel Secret { get; set; } = new();

    private bool _copied;

    private async Task CopyToClipboardAsync(string text)
    {
        try
        {
            await JsRuntime.InvokeVoidAsync("navigator.clipboard.writeText", text);
            _copied = true;
            StateHasChanged();

            // Reset the copied indicator after 2 seconds
            await Task.Delay(2000);
            _copied = false;
            StateHasChanged();
        }
        catch
        {
            // Clipboard API may not be available in all contexts
        }
    }

    private void Close()
    {
        MudDialog.Close(DialogResult.Ok(true));
    }
}
