@implements IDisposable
@inject EventsHubConnection EventsHub
@inject ISnackbar Snackbar
@using Sorcha.UI.Core.Models.Admin
@using Sorcha.UI.Core.Services
@using MudBlazor

@code {
    /// <inheritdoc />
    protected override void OnInitialized()
    {
        EventsHub.OnEncryptionOperationCompleted += HandleOperationCompleted;
    }

    private void HandleOperationCompleted(EncryptionOperationCompletedDto dto)
    {
        if (dto.IsSuccess)
        {
            Snackbar.Add($"Encryption completed — Transaction: {dto.TransactionHash}", Severity.Success);
        }
        else
        {
            Snackbar.Add($"Encryption failed: {dto.ErrorMessage}", Severity.Error);
        }
    }

    /// <inheritdoc />
    public void Dispose()
    {
        EventsHub.OnEncryptionOperationCompleted -= HandleOperationCompleted;
    }
}
