@using MudBlazor
@using Sorcha.UI.Core.Models.Admin
@using Sorcha.UI.Core.Models.Workflows
@using Sorcha.UI.Core.Services
@using Sorcha.UI.Core.Services.Admin
@implements IDisposable
@inject IOperationStatusService OperationService

<MudPaper Elevation="2" Class="pa-4">
    <MudStack Spacing="2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" />
            <MudText Typo="Typo.subtitle1">Encryption Progress</MudText>
        </MudStack>

        @if (_isLoading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        else if (_operation is not null)
        {
            @if (_operation.IsComplete && _operation.IsSuccess)
            {
                <MudAlert Severity="Severity.Success" Dense="true">
                    Encryption complete
                    @if (!string.IsNullOrWhiteSpace(_operation.TransactionHash))
                    {
                        <span> — Transaction: <code>@_operation.TransactionHash</code></span>
                    }
                </MudAlert>
            }
            else if (_operation.IsComplete && !_operation.IsSuccess)
            {
                <MudAlert Severity="Severity.Error" Dense="true">
                    Encryption failed@(!string.IsNullOrWhiteSpace(_operation.ErrorMessage) ? $": {_operation.ErrorMessage}" : "")
                </MudAlert>

                @if (OriginalRequest is not null)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Refresh"
                               OnClick="RetryAsync"
                               Disabled="_isRetrying">
                        @if (_isRetrying)
                        {
                            <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
                        }
                        Retry
                    </MudButton>
                }
            }
            else
            {
                <MudProgressLinear Color="Color.Primary"
                                   Value="@_operation.PercentComplete"
                                   Max="100"
                                   Indeterminate="@(_operation.PercentComplete == 0)" />

                @if (!string.IsNullOrWhiteSpace(_operation.Stage))
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @FormatStage(_operation.Stage)
                    </MudText>
                }

                <MudText Typo="Typo.caption">
                    @_operation.ProcessedRecipients of @_operation.RecipientCount recipients processed
                </MudText>
            }
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public string OperationId { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnCompleted { get; set; }

    [Parameter]
    public EventCallback OnFailed { get; set; }

    /// <summary>
    /// Original action request for retry capability. When provided and operation fails,
    /// a retry button is shown.
    /// </summary>
    [Parameter]
    public ActionExecuteRequest? OriginalRequest { get; set; }

    /// <summary>
    /// Optional WorkflowService for retry submissions.
    /// </summary>
    [Parameter]
    public IWorkflowService? WorkflowService { get; set; }

    private EncryptionOperationViewModel? _operation;
    private System.Timers.Timer? _pollTimer;
    private bool _isLoading = true;
    private bool _isRetrying;
    private bool _disposed;
    private string _currentOperationId = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _currentOperationId = OperationId;
        await PollStatusAsync();
        if (_operation != null && !_operation.IsComplete)
        {
            StartPolling();
        }
    }

    private void StartPolling()
    {
        _pollTimer = new System.Timers.Timer(2000);
        _pollTimer.Elapsed += async (_, _) => await InvokeAsync(PollStatusAsync);
        _pollTimer.AutoReset = true;
        _pollTimer.Start();
    }

    private void StopPolling()
    {
        _pollTimer?.Stop();
        _pollTimer?.Dispose();
        _pollTimer = null;
    }

    private async Task PollStatusAsync()
    {
        if (_disposed) return;
        _operation = await OperationService.GetStatusAsync(_currentOperationId);
        _isLoading = false;

        if (_operation?.IsComplete == true)
        {
            StopPolling();
            if (_operation.IsSuccess)
            {
                await OnCompleted.InvokeAsync();
            }
            else
            {
                await OnFailed.InvokeAsync();
            }
        }

        StateHasChanged();
    }

    private async Task RetryAsync()
    {
        if (OriginalRequest is null || WorkflowService is null) return;

        _isRetrying = true;
        StateHasChanged();

        try
        {
            var result = await WorkflowService.SubmitActionExecuteAsync(OriginalRequest);
            if (result?.HasAsyncOperation == true)
            {
                // Reset state for new operation
                _currentOperationId = result.OperationId!;
                _operation = null;
                _isLoading = true;
                _isRetrying = false;
                StateHasChanged();

                await PollStatusAsync();
                if (_operation != null && !_operation.IsComplete)
                {
                    StartPolling();
                }
            }
            else
            {
                _isRetrying = false;
                // Sync result — operation completed immediately
                await OnCompleted.InvokeAsync();
            }
        }
        catch
        {
            _isRetrying = false;
            StateHasChanged();
        }
    }

    private static string FormatStage(string stage) =>
        string.Join(' ', stage.Replace("-", " ").Split(' ')
            .Select(w => w.Length > 0 ? char.ToUpperInvariant(w[0]) + w[1..] : w));

    public void Dispose()
    {
        _disposed = true;
        StopPolling();
    }
}
