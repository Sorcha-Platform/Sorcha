<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>Sorcha.Blueprint.Models</PackageId>
    <Version>2.2.0</Version>
    <Description>Domain models with JSON-LD for blueprint workflow definitions</Description>
    <PackageTags>sorcha;blueprint;models;json-ld;workflow</PackageTags>
    <RootNamespace>Sorcha.Blueprint.Models</RootNamespace>
    <!-- CS1591: Suppress missing XML doc warnings for internal types; public API is documented -->
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="FluentValidation" />
    <PackageReference Include="JsonLogic" />
    <PackageReference Include="JsonSchema.Net" />
    <PackageReference Include="JsonSchema.Net.Generation" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Sorcha.Blueprint.Models.Tests" />
    <InternalsVisibleTo Include="Sorcha.Blueprint.Fluent.Tests" />
  </ItemGroup>

</Project>
