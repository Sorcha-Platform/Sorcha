<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>Sorcha.ServiceClients</PackageId>
    <Version>2.0.0</Version>
    <Description>Consolidated HTTP and gRPC service clients with auth and resilience</Description>
    <PackageTags>sorcha;service-clients;grpc;http;resilience</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <!-- gRPC and HTTP client dependencies -->
    <PackageReference Include="Grpc.Net.Client" />
    <PackageReference Include="Grpc.Tools">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Google.Protobuf" />
    <PackageReference Include="Microsoft.Extensions.Http" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" />
    <PackageReference Include="SimpleBase" />
  </ItemGroup>

  <ItemGroup>
    <!-- Reference common models -->
    <ProjectReference Include="..\Sorcha.Register.Models\Sorcha.Register.Models.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Peer Service protos — generate Both (client + server + messages) so that
         Peer.Service can reference these types instead of compiling the same protos,
         which would produce duplicate message types (CS0436). -->
    <Protobuf Include="..\..\Services\Sorcha.Peer.Service\Protos\peer_communication.proto" GrpcServices="Both" Link="Protos\peer_communication.proto" />
    <Protobuf Include="..\..\Services\Sorcha.Peer.Service\Protos\peer_discovery.proto" GrpcServices="Both" Link="Protos\peer_discovery.proto" />
    <!-- Feature 047: Inbound transaction routing — client stubs for cross-service gRPC calls -->
    <Protobuf Include="..\..\Services\Sorcha.Register.Service\Protos\register_address.proto" GrpcServices="Client" Link="Protos\register_address.proto" />
    <Protobuf Include="..\..\Services\Sorcha.Wallet.Service\Protos\wallet_notification.proto" GrpcServices="Client" Link="Protos\wallet_notification.proto" />
    <Protobuf Include="..\..\Services\Sorcha.Peer.Service\Protos\docket_sync.proto" GrpcServices="Client" Link="Protos\docket_sync.proto" />
  </ItemGroup>

</Project>
