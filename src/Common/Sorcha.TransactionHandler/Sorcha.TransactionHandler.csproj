<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageId>Sorcha.TransactionHandler</PackageId>
    <Version>2.0.0</Version>
    <Description>Transaction building, signing, and serialization for the Sorcha distributed ledger platform</Description>
    <PackageTags>sorcha;transaction;signing;serialization;distributed-ledger</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <NoWarn>$(NoWarn);1591</NoWarn>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <!-- Core dependency -->
    <ProjectReference Include="..\Sorcha.Cryptography\Sorcha.Cryptography.csproj" />
    <ProjectReference Include="..\Sorcha.Blueprint.Models\Sorcha.Blueprint.Models.csproj" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
  </ItemGroup>

  <ItemGroup>
    <!-- Package README -->
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
