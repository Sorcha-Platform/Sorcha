@page "/auth/reset-password"
@model Sorcha.Tenant.Service.Pages.Auth.ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="auth-card">
    <div class="auth-header">
        <h2>Reset Password</h2>
        @if (Model.Mode == "reset")
        {
            <p>Choose a new password for your account</p>
        }
        else
        {
            <p>Enter your email to receive a reset link</p>
        }
    </div>
    <div class="auth-card-body">

        @* ── Request mode ── *@
        @if (Model.Mode == "request")
        {
            @if (Model.RequestSent)
            {
                <div class="auth-result auth-result-success">
                    <span class="auth-result-icon" aria-hidden="true">&#9993;</span>
                    <h3>Check your email</h3>
                    <p>If an account exists for that address, we've sent a password reset link. It expires in 1 hour.</p>
                    <a href="/auth/login" class="btn btn-secondary btn-lg w-100 mt-3">Back to Sign In</a>
                </div>
            }
            else
            {
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger" role="alert">
                        @Model.ErrorMessage
                    </div>
                }

                <form method="post" asp-page-handler="Request">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label" for="email-input">Email address</label>
                        <input type="email" id="email-input" asp-for="Email" class="form-control form-control-lg"
                               placeholder="you@@example.com" autofocus autocomplete="email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100">Send Reset Link</button>
                </form>

                <div class="text-center mt-4">
                    <p class="text-muted">
                        <a href="/auth/login">Back to Sign In</a>
                    </p>
                </div>
            }
        }

        @* ── Reset mode ── *@
        @if (Model.Mode == "reset")
        {
            @if (Model.ResetSuccess)
            {
                <div class="auth-result auth-result-success">
                    <span class="auth-result-icon" aria-hidden="true">&#10003;</span>
                    <h3>Password reset!</h3>
                    <p>Your password has been successfully updated. You can now sign in with your new password.</p>
                    <a href="/auth/login" class="btn btn-primary btn-lg w-100 mt-3">Sign In</a>
                </div>
            }
            else if (!string.IsNullOrEmpty(Model.ErrorMessage) && string.IsNullOrWhiteSpace(Model.Token))
            {
                <div class="auth-result auth-result-error">
                    <span class="auth-result-icon" aria-hidden="true">&#10007;</span>
                    <h3>Invalid reset link</h3>
                    <p>@Model.ErrorMessage</p>
                    <a href="/auth/reset-password" class="btn btn-secondary btn-lg w-100 mt-3">Request a New Link</a>
                </div>
            }
            else
            {
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger" role="alert">
                        @Model.ErrorMessage
                    </div>
                }

                @if (Model.ValidationErrors is { Count: > 0 })
                {
                    <div class="alert alert-danger" role="alert">
                        <ul class="mb-0 ps-3">
                            @foreach (var (field, errors) in Model.ValidationErrors)
                            {
                                foreach (var error in errors)
                                {
                                    <li>@error</li>
                                }
                            }
                        </ul>
                    </div>
                }

                <form method="post" asp-page-handler="Reset">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Token" />
                    <div class="mb-3">
                        <label class="form-label" for="new-password-input">New password</label>
                        <input type="password" id="new-password-input" asp-for="NewPassword"
                               class="form-control form-control-lg"
                               placeholder="Enter new password" autocomplete="new-password" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label" for="confirm-password-input">Confirm password</label>
                        <input type="password" id="confirm-password-input" asp-for="ConfirmPassword"
                               class="form-control form-control-lg"
                               placeholder="Repeat new password" autocomplete="new-password" />
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100">Reset Password</button>
                </form>
            }
        }

    </div>
</div>
