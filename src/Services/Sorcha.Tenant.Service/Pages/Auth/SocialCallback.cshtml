@page "/auth/social/callback"
@model Sorcha.Tenant.Service.Pages.Auth.SocialCallbackModel
@{
    ViewData["Title"] = "Completing Sign-In";
}

<div class="auth-card">
    <div class="auth-header">
        <h2>Sign In</h2>
        <p>Completing your sign-in</p>
    </div>
    <div class="auth-card-body">
        @if (Model.IsProcessing)
        {
            <div class="auth-processing text-center">
                <div class="spinner-border text-primary mb-3" role="status" aria-label="Loading">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="text-muted">Completing sign-in...</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="auth-result">
                <div class="alert alert-danger" role="alert">
                    @Model.ErrorMessage
                </div>
                <div class="text-center mt-3">
                    <a href="/auth/signup" class="btn btn-primary">Back to Sign Up</a>
                </div>
            </div>
        }
    </div>
</div>
